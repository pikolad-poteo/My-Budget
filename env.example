# =========================
# My Budget environment
# =========================

# development | production | test
NODE_ENV=development

# Local server port
PORT=3000

# Public application URL
# Local:
APP_URL=http://localhost:3000
# Production example:
# APP_URL=https://your-domain.ee

# =========================
# Database
# =========================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=my_budget

# =========================
# Session
# =========================

# Required. Do not use this example value in production.
# Generate a long random value for real .env.
SESSION_SECRET=replace_this_with_a_long_random_secret

# =========================
# Email / SMTP
# =========================

MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="My Budget <no-reply@your-domain.ee>"

# =========================
# Security / tests
# =========================

# Use false in normal development.
# Can be true only for tests/debug.
RATE_LIMIT_DISABLED=false
CSRF_DISABLED=false
