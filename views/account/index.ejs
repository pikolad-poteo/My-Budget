<% /* Account settings page with profile, email, password and danger-zone sections. */ %>
<%- include('../partials/header') %>

<%
  const familyRole = accountFamilyRole && accountFamilyRole.role ? String(accountFamilyRole.role).toLowerCase() : 'personal';
  const normalizedRole = ['owner', 'editor', 'viewer'].includes(familyRole) ? familyRole : 'member';
  const accountRoleLabels = {
    owner: t('account.roles.owner'),
    editor: t('account.roles.editor'),
    viewer: t('account.roles.viewer'),
    member: t('account.roles.personal')
  };
  const familyRoleTitle = accountRoleLabels[normalizedRole] || accountRoleLabels.member;
  const personalWorkspaceLabel = t('account.personalWorkspace');
  const familyRoleSubtitle = accountFamilyRole && accountFamilyRole.family_name ? accountFamilyRole.family_name : personalWorkspaceLabel;
  const familyName = accountFamilyRole && accountFamilyRole.family_name ? accountFamilyRole.family_name : personalWorkspaceLabel;
  const familyAvatarUrl = accountFamilyRole && accountFamilyRole.family_avatar_url ? accountFamilyRole.family_avatar_url : '';
  const accountDateLocales = { en: 'en-US', ru: 'ru-RU', et: 'et-EE' };
  const memberSince = accountUser.created_at
    ? new Date(accountUser.created_at).toLocaleDateString(accountDateLocales[language] || 'en-US', { month: 'long', day: 'numeric', year: 'numeric' })
    : '';
%>

<section class="container account-page">
  <section class="account-overview-card">
    <p class="section-label"><%= t('account.personalWorkspace') %></p>
    <h1 class="account-title"><%= t('account.title') %></h1>
    <p class="account-overview-description">
      <%= t('account.description') %>
    </p>
  </section>

  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-4 account-alert" role="alert"><%= errorMessage %></div>
  <% } %>

  <% if (successMessage) { %>
    <div class="alert alert-success rounded-4 account-alert" role="alert"><%= successMessage %></div>
  <% } %>

  <section class="account-settings-card">
    <div class="account-settings-layout">
      <aside class="account-left-column">
        <section class="account-panel account-avatar-panel">
          <h2><%= t('account.avatar') %></h2>

          <div class="account-avatar-editor">
            <button class="account-avatar-button" type="button" id="accountAvatarTrigger" aria-label="<%= t('account.changeAvatar') %>">
              <% if (accountUser.avatar_url) { %>
                <img class="account-avatar account-avatar-xl" src="<%= accountUser.avatar_url %>" alt="<%= t('account.userAvatarAlt', { name: accountUser.name }) %>" />
              <% } else { %>
                <span class="account-avatar account-avatar-xl account-avatar-fallback" aria-hidden="true">
                  <i class="bi bi-person account-avatar-fallback-icon"></i>
                </span>
              <% } %>
              <span class="account-avatar-edit-hint"><i class="bi bi-camera"></i></span>
            </button>

            <div class="account-avatar-user-preview">
              <h3><%= accountUser.name %></h3>
              <p><%= accountUser.email %></p>
              <% if (memberSince) { %>
                <span><%= t('account.memberSince') %> <%= memberSince %></span>
              <% } %>
            </div>

            <p class="account-avatar-help"><%= t('account.avatarHelp') %></p>
          </div>

          <form action="/account/avatar?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="d-none" id="accountAvatarForm">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input id="accountAvatarInput" name="avatar" type="file" accept="image/jpeg,image/png,.jpg,.jpeg,.png" data-invalid-type="<%= t('account.messages.uploadJpgPngOnly') %>" data-too-large="<%= t('account.messages.avatarTooLarge') %>" />
          </form>

          <% if (accountUser.avatar_url) { %>
            <form action="/account/avatar/delete" method="POST" class="account-avatar-delete-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-primary rounded-pill px-4" type="submit"><%= t('account.deleteAvatar') %></button>
            </form>
          <% } %>
        </section>

        <div class="account-inner-divider"></div>

        <div class="account-summary-stack">
          <section class="account-panel account-family-panel">
            <div class="account-info-summary-card account-family-summary-card">
              <span class="account-family-avatar" aria-hidden="true">
                <% if (familyAvatarUrl) { %>
                  <img src="<%= familyAvatarUrl %>" alt="<%= t('account.familyAvatarAlt') %>" />
                <% } else { %>
                  <i class="bi bi-people-fill"></i>
                <% } %>
              </span>
              <div>
                <span><%= t('account.yourFamily') %></span>
                <strong><%= familyName %></strong>
              </div>
            </div>
          </section>

          <section class="account-panel account-role-panel">
            <div class="family-readonly-field family-role-summary-card account-family-role-card">
              <span class="family-role-icon family-role-icon-<%= normalizedRole || 'member' %>" aria-hidden="true">
                <% if (normalizedRole === 'owner') { %>
                  <svg class="family-role-svg" viewBox="0 0 16 16" role="img" aria-label="<%= t('account.ownerCrown') %>" focusable="false">
                    <path d="M3.1 12.4h9.8l.7-6.8a.5.5 0 0 0-.82-.43L10.3 7.3 8.45 3.45a.5.5 0 0 0-.9 0L5.7 7.3 3.22 5.17a.5.5 0 0 0-.82.43l.7 6.8Zm.2 1.1a.5.5 0 0 0 .5.5h8.4a.5.5 0 0 0 .5-.5v-.3H3.3v.3Z" fill="currentColor"/>
                  </svg>
                <% } else if (normalizedRole === 'editor') { %>
                  <i class="bi bi-pencil-fill"></i>
                <% } else if (normalizedRole === 'viewer') { %>
                  <i class="bi bi-eye-fill"></i>
                <% } else { %>
                  <i class="bi bi-person-fill"></i>
                <% } %>
              </span>
              <div>
                <span><%= t('account.yourRole') %></span>
                <strong><%= familyRoleTitle %></strong>
                <small><%= familyRoleSubtitle %></small>
              </div>
            </div>
          </section>
        </div>
      </aside>

      <div class="account-vertical-divider"></div>

      <div class="account-right-column">
        <section class="account-panel account-profile-panel">
          <h2><%= t('account.profileSettings') %></h2>

          <form action="/account/profile" method="POST" class="account-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label class="form-label" for="name"><%= t('account.name') %></label>
              <input class="form-control form-input" id="name" name="name" type="text" value="<%= accountUser.name %>" maxlength="100" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="email"><%= t('account.email') %></label>
              <input class="form-control form-input" id="email" name="email" type="email" value="<%= accountUser.email %>" maxlength="150" required />
              <small class="text-muted"><%= t('account.currentEmailActiveHint') %></small>
            </div>

            <% if (accountUser.pending_email) { %>
              <div class="alert alert-warning rounded-4 account-alert" role="status">
                <strong><%= t('account.pendingEmailTitle') %></strong><br />
                <%= t('account.pendingEmailText') %> <strong><%= accountUser.pending_email %></strong>
                <div class="mt-2">
                  <button class="btn btn-outline-secondary rounded-pill px-4 btn-sm" type="submit" formaction="/account/email-change/cancel" formmethod="POST" formnovalidate><%= t('account.cancelPendingEmail') %></button>
                </div>
              </div>
            <% } %>

            <button class="btn btn-primary rounded-pill px-4 account-submit-btn" type="submit"><%= t('account.saveChanges') %></button>
          </form>
        </section>

        <div class="account-inner-divider"></div>

        <section class="account-panel account-password-panel">
          <h2><%= t('account.changePassword') %></h2>

          <form action="/account/password" method="POST" class="account-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
              <label class="form-label" for="currentPassword"><%= t('account.currentPassword') %></label>
              <input class="form-control form-input" id="currentPassword" name="currentPassword" type="password" autocomplete="current-password" placeholder="<%= t('account.currentPasswordPlaceholder') %>" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="newPassword"><%= t('account.newPassword') %></label>
              <input class="form-control form-input" id="newPassword" name="newPassword" type="password" autocomplete="new-password" placeholder="<%= t('account.newPasswordPlaceholder') %>" minlength="8" title="<%= t('account.passwordHint') %>" required />
              <small class="text-muted d-block mt-2"><%= t('account.passwordHint') %></small>
            </div>

            <div class="form-group">
              <label class="form-label" for="confirmPassword"><%= t('account.repeatNewPassword') %></label>
              <input class="form-control form-input" id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" placeholder="<%= t('account.repeatNewPasswordPlaceholder') %>" minlength="8" required />
            </div>

            <button class="btn btn-primary rounded-pill px-4 account-submit-btn" type="submit"><%= t('account.updatePassword') %></button>
          </form>
        </section>
      </div>
    </div>
  </section>

  <section class="account-danger-card account-danger-card-wide">
    <div class="account-danger-content">
      <span class="account-danger-icon"><i class="bi bi-exclamation-octagon"></i></span>
      <div>
        <h2><%= t('account.dangerZone') %></h2>
        <p><%= t('account.dangerDescription') %></p>
      </div>
    </div>

    <div class="account-danger-action">
      <button class="btn btn-outline-danger rounded-pill px-4" type="button" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
        <%= t('account.deleteAccount') %>
      </button>
      <span><%= t('account.deleteAccountHint') %></span>
    </div>
  </section>
</section>

<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content account-modal-content account-delete-modal-content">
      <div class="modal-header border-0 pb-0">
        <div>
          <p class="section-label mb-1 text-danger"><%= t('account.dangerZone') %></p>
          <h2 class="modal-title account-modal-title" id="deleteAccountModalLabel"><%= t('account.deleteAccountTitle') %></h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('account.close') %>"></button>
      </div>

      <form action="/account/delete" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body pt-3">
          <p class="account-modal-note">
            <%= t('account.deleteAccountWarning') %>
          </p>
          <p class="account-modal-note mb-3">
            <%= t('account.typeDeletePrefix') %> <strong>DELETE</strong> <%= t('account.typeDeleteSuffix') %>
          </p>
          <input class="form-control rounded-pill" name="confirmation" type="text" placeholder="DELETE" autocomplete="off" required />
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal"><%= t('account.cancel') %></button>
          <button type="submit" class="btn btn-danger rounded-pill px-4"><%= t('account.deleteForever') %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/account.js"></script>

<%- include('../partials/footer') %>
