<% /* Calendar page shell that combines controls, month grid, selected-day details and event form partials. */ %>
<%- include('../partials/header') %>

<section class="container calendar-shell">
  <% if (successMessage) { %>
    <div class="alert alert-success rounded-3 mb-0" role="alert"><%= successMessage %></div>
  <% } %>
  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-3 mb-0" role="alert"><%= errorMessage %></div>
  <% } %>

  <%- include('../partials/page-overview', {
    eyebrow: t('calendar.management'),
    heading: t('calendar.overviewTitle'),
    description: t('calendar.overviewDescription'),
    buttonId: 'toggleCalendarCreateButton',
    buttonTextId: 'toggleCalendarCreateButtonText',
    controlsId: 'calendarCreatePanel',
    buttonLabel: t('calendar.addEvent'),
    stats: [
      { value: summary.monthTotal, label: t('calendar.monthEvents') },
      { value: summary.dayTotal, label: t('calendar.selectedDay') },
      { value: summary.important, label: t('calendar.important') },
      { value: family ? t('calendar.on') : t('calendar.off'), label: t('calendar.familyMode') }
    ],
    createContent: `<div class="calendar-create-panel-inline" id="calendarCreatePanel" hidden>${include('_form_new', { members, selectedDate, calendarView, family, t })}</div>`
  }) %>

  <section id="calendarWorkArea" class="card border-0 shadow-sm rounded-4 section-card calendar-controls-panel">
    <div class="card-body p-4">
      <div class="calendar-controls-header">
        <div class="calendar-controls-left">
          <div class="calendar-controls-title">
            <p class="section-label"><%= t('calendar.controls') %></p>
            <h2 class="mb-0"><%= calendarView === 'month' ? monthTitle : formattedSelectedDate %></h2>
          </div>

          <div class="calendar-nav-group" aria-label="<%= t('calendar.navigation') %>">
            <% if (calendarView === 'month') { %>
              <a href="/calendar?view=month&date=<%= nav.prevMonth %>" class="calendar-nav-btn" data-calendar-ajax aria-label="<%= t('calendar.previousMonth') %>">
                <i class="bi bi-chevron-left"></i>
              </a>

              <a href="/calendar?view=month&date=<%= nav.today %>" class="calendar-toolbar-btn" data-calendar-ajax>
                <%= t('calendar.today') %>
              </a>

              <a href="/calendar?view=month&date=<%= nav.nextMonth %>" class="calendar-nav-btn" data-calendar-ajax aria-label="<%= t('calendar.nextMonth') %>">
                <i class="bi bi-chevron-right"></i>
              </a>
            <% } else { %>
              <a href="/calendar?view=day&date=<%= nav.prevDay %>" class="calendar-nav-btn" data-calendar-ajax aria-label="<%= t('calendar.previousDay') %>">
                <i class="bi bi-chevron-left"></i>
              </a>

              <a href="/calendar?view=day&date=<%= nav.today %>" class="calendar-toolbar-btn" data-calendar-ajax>
                <%= t('calendar.today') %>
              </a>

              <a href="/calendar?view=day&date=<%= nav.nextDay %>" class="calendar-nav-btn" data-calendar-ajax aria-label="<%= t('calendar.nextDay') %>">
                <i class="bi bi-chevron-right"></i>
              </a>
            <% } %>
          </div>
        </div>

        <div class="calendar-view-switch" role="group" aria-label="<%= t('calendar.view') %>">
          <a href="/calendar?view=month&date=<%= selectedDate %>" data-calendar-ajax class="calendar-view-btn <%= calendarView === 'month' ? 'is-active' : '' %>">
            <%= t('calendar.month') %>
          </a>
          <a href="/calendar?view=day&date=<%= selectedDate %>" data-calendar-ajax class="calendar-view-btn <%= calendarView === 'day' ? 'is-active' : '' %>">
            <%= t('calendar.day') %>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="card border-0 shadow-sm rounded-4 section-card calendar-board-panel">
    <div class="card-body p-3 p-lg-4">
      <div class="section-header calendar-section-heading">
        <div>
          <p class="section-label"><%= calendarView === 'month' ? t('calendar.monthView') : t('calendar.dayView') %></p>
          <h2><%= calendarView === 'month' ? t('calendar.monthCalendar') : formattedSelectedDate %></h2>
        </div>

        <% if (calendarView === 'month') { %>
          <a href="/calendar?view=day&date=<%= selectedDate %>" data-calendar-ajax class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <%= t('calendar.openSelectedDay') %>
          </a>
        <% } else { %>
          <a href="/calendar?view=month&date=<%= selectedDate %>" data-calendar-ajax class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <%= t('calendar.backToMonth') %>
          </a>
        <% } %>
      </div>

      <% if (calendarView === 'month') { %>
        <%- include('_month_view', { monthMatrix, selectedDate, t }) %>
      <% } else { %>
        <%- include('_day_view', { dayEvents, selectedDate, formattedSelectedDate, calendarView, members, t }) %>
      <% } %>
    </div>
  </section>

  <% if (calendarView === 'month') { %>
    <section class="card border-0 shadow-sm rounded-4 section-card calendar-selected-panel">
      <div class="card-body p-4">
        <div class="section-header calendar-section-heading">
          <div>
            <p class="section-label"><%= t('calendar.selectedDate') %></p>
            <h2><%= formattedSelectedDate %></h2>
          </div>

          <a href="/calendar?view=day&date=<%= selectedDate %>" data-calendar-ajax class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <%= t('calendar.dayView') %>
          </a>
        </div>

        <%- include('_day_view', { dayEvents, selectedDate, formattedSelectedDate, calendarView, members, t }) %>
      </div>
    </section>
  <% } %>
</section>

<script>
  window.calendarI18n = {
    addEvent: '<%- t("calendar.addEvent") %>',
    hideForm: '<%- t("calendar.hideForm") %>'
  };
</script>
<script src="/js/calendar.js"></script>

<%- include('../partials/footer') %>
