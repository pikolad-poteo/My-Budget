<%- include('../partials/header') %>

<section class="container calendar-shell">
  <% if (successMessage) { %>
    <div class="alert alert-success rounded-3 mb-0" role="alert"><%= successMessage %></div>
  <% } %>
  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-3 mb-0" role="alert"><%= errorMessage %></div>
  <% } %>

  <%- include('../partials/page-overview', {
    eyebrow: 'Management',
    heading: 'Calendar overview',
    description: 'Manage family events, reminders, tasks, and important dates in one clean workspace.',
    buttonId: 'toggleCalendarCreateButton',
    buttonTextId: 'toggleCalendarCreateButtonText',
    controlsId: 'calendarCreatePanel',
    buttonLabel: 'Add event',
    stats: [
      { value: summary.monthTotal, label: 'Month events' },
      { value: summary.dayTotal, label: 'Selected day' },
      { value: summary.important, label: 'Important' },
      { value: family ? 'On' : 'Off', label: 'Family mode' }
    ],
    createContent: `<div class="calendar-create-panel-inline" id="calendarCreatePanel" hidden>${include('_form_new', { members, selectedDate, calendarView, family })}</div>`
  }) %>

  <section id="calendarWorkArea" class="card border-0 shadow-sm rounded-4 section-card calendar-controls-panel">
    <div class="card-body p-4">
      <div class="calendar-controls-header">
        <div class="calendar-controls-left">
          <div class="calendar-controls-title">
            <p class="section-label">Calendar controls</p>
            <h2 class="mb-0"><%= calendarView === 'month' ? monthTitle : formattedSelectedDate %></h2>
          </div>

          <div class="calendar-nav-group" aria-label="Calendar navigation">
            <% if (calendarView === 'month') { %>
              <a href="/calendar?view=month&date=<%= nav.prevMonth %>" class="calendar-nav-btn" data-calendar-ajax aria-label="Previous month">
                <i class="bi bi-chevron-left"></i>
              </a>

              <a href="/calendar?view=month&date=<%= nav.today %>" class="calendar-toolbar-btn" data-calendar-ajax>
                Today
              </a>

              <a href="/calendar?view=month&date=<%= nav.nextMonth %>" class="calendar-nav-btn" data-calendar-ajax aria-label="Next month">
                <i class="bi bi-chevron-right"></i>
              </a>
            <% } else { %>
              <a href="/calendar?view=day&date=<%= nav.prevDay %>" class="calendar-nav-btn" data-calendar-ajax aria-label="Previous day">
                <i class="bi bi-chevron-left"></i>
              </a>

              <a href="/calendar?view=day&date=<%= nav.today %>" class="calendar-toolbar-btn" data-calendar-ajax>
                Today
              </a>

              <a href="/calendar?view=day&date=<%= nav.nextDay %>" class="calendar-nav-btn" data-calendar-ajax aria-label="Next day">
                <i class="bi bi-chevron-right"></i>
              </a>
            <% } %>
          </div>
        </div>

        <div class="calendar-view-switch" role="group" aria-label="Calendar view">
          <a href="/calendar?view=month&date=<%= selectedDate %>" data-calendar-ajax class="calendar-view-btn <%= calendarView === 'month' ? 'is-active' : '' %>">
            Month
          </a>
          <a href="/calendar?view=day&date=<%= selectedDate %>" data-calendar-ajax class="calendar-view-btn <%= calendarView === 'day' ? 'is-active' : '' %>">
            Day
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="card border-0 shadow-sm rounded-4 section-card calendar-board-panel">
    <div class="card-body p-3 p-lg-4">
      <div class="section-header calendar-section-heading">
        <div>
          <p class="section-label"><%= calendarView === 'month' ? 'Month view' : 'Day view' %></p>
          <h2><%= calendarView === 'month' ? 'Month calendar' : formattedSelectedDate %></h2>
        </div>

        <% if (calendarView === 'month') { %>
          <a href="/calendar?view=day&date=<%= selectedDate %>" data-calendar-ajax class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            Open selected day
          </a>
        <% } else { %>
          <a href="/calendar?view=month&date=<%= selectedDate %>" data-calendar-ajax class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            Back to month
          </a>
        <% } %>
      </div>

      <% if (calendarView === 'month') { %>
        <%- include('_month_view', { monthMatrix, selectedDate }) %>
      <% } else { %>
        <%- include('_day_view', { dayEvents, selectedDate, formattedSelectedDate, calendarView, members }) %>
      <% } %>
    </div>
  </section>

  <% if (calendarView === 'month') { %>
    <section class="card border-0 shadow-sm rounded-4 section-card calendar-selected-panel">
      <div class="card-body p-4">
        <div class="section-header calendar-section-heading">
          <div>
            <p class="section-label">Selected date</p>
            <h2><%= formattedSelectedDate %></h2>
          </div>

          <a href="/calendar?view=day&date=<%= selectedDate %>" data-calendar-ajax class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            Day view
          </a>
        </div>

        <%- include('_day_view', { dayEvents, selectedDate, formattedSelectedDate, calendarView, members }) %>
      </div>
    </section>
  <% } %>
</section>

<script src="/js/calendar.js"></script>

<%- include('../partials/footer') %>
