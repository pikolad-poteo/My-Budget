<% /* Reusable category list partial for income and expense groups. */ %>
<% if (categories.length === 0) { %>
  <div class="categories-empty-state">
    <span class="categories-empty-icon"><i class="bi bi-tags"></i></span>
    <h3><%= emptyTitle %></h3>
    <p><%= emptyText %></p>
  </div>
<% } else { %>
  <div class="categories-card-grid" data-category-list="<%= typeKey %>" data-category-view-panel="cards">
    <% categories.forEach((category) => { %>
      <% const isDashboardFeatured = Boolean(category.dashboard_featured || category.dashboardFeatured || category.show_on_dashboard || category.showOnDashboard || category.is_dashboard_highlight || category.isDashboardHighlight); %>
      <div
        class="category-card-cell"
        data-category-item
        data-category-name="<%= category.name %>"
      >
        <button
          type="button"
          class="category-card"
          data-open-category-modal="category-modal-<%= category.id %>"
          style="--category-color: <%= category.color || '#6c757d' %>; --category-soft: <%= hexToRgba(category.color, 0.12) %>; --category-border: <%= hexToRgba(category.color, 0.22) %>;"
        >
          <span class="category-card-inner">
            <span class="category-card-icon">
              <i class="bi bi-<%= category.icon || 'tag' %>"></i>
            </span>

            <span class="category-card-info">
              <strong class="category-card-title"><%= category.name %></strong>
              <span class="category-card-meta">
                <span class="category-badge"><%= getTypeLabel(category.type) %></span>
                <% if (isDashboardFeatured) { %>
                  <span class="category-dashboard-marker" title="<%= t('categories.shownOnDashboard') %>" aria-label="<%= t('categories.shownOnDashboard') %>">
                    <i class="bi bi-star-fill"></i>
                  </span>
                <% } %>
              </span>
              <span class="category-card-hint"><%= t('categories.clickToChange') %></span>
            </span>
          </span>
        </button>
      </div>
    <% }) %>

    <div class="category-card-cell" data-category-add-card>
      <button class="category-card category-card-add" type="button" data-add-card-type="<%= typeKey %>">
        <span class="category-add-icon"><i class="bi bi-plus-lg"></i></span>
        <strong><%= addButtonTitle %></strong>
        <span><%= addButtonText %></span>
      </button>
    </div>
  </div>

  <div class="categories-list-view" data-category-view-panel="list" hidden>
    <% categories.forEach((category) => { %>
      <% const isDashboardFeatured = Boolean(category.dashboard_featured || category.dashboardFeatured || category.show_on_dashboard || category.showOnDashboard || category.is_dashboard_highlight || category.isDashboardHighlight); %>
      <div
        class="category-list-row"
        data-category-item
        data-category-name="<%= category.name %>"
        style="--category-color: <%= category.color || '#6c757d' %>; --category-soft: <%= hexToRgba(category.color, 0.12) %>;"
      >
        <span class="category-list-icon">
          <i class="bi bi-<%= category.icon || 'tag' %>"></i>
        </span>

        <div class="category-list-name">
          <strong><%= category.name %></strong>
        </div>

        <span class="category-list-type">
          <span class="category-badge category-list-badge"><%= getTypeLabel(category.type) %></span>
          <% if (isDashboardFeatured) { %>
            <span class="category-dashboard-marker" title="<%= t('categories.shownOnDashboard') %>" aria-label="<%= t('categories.shownOnDashboard') %>">
              <i class="bi bi-star-fill"></i>
            </span>
          <% } %>
        </span>

        <button type="button" class="category-list-edit-btn" data-open-category-modal="category-modal-<%= category.id %>">
          <%= t('categories.editCategory') %>
        </button>
      </div>
    <% }) %>
  </div>

  <% categories.forEach((category) => { %>
    <div class="category-modal" id="category-modal-<%= category.id %>" hidden>
      <div class="category-modal-backdrop" data-close-category-modal></div>
      <div class="category-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="category-modal-title-<%= category.id %>">
        <%- include('./_edit_form', {
          category,
          activeTab,
          currentSearch,
          iconOptions,
          colorOptions,
          typeKey
        }) %>
      </div>
    </div>
  <% }) %>

  <div class="categories-empty-state categories-empty-state--filtered" data-category-filter-empty="<%= typeKey %>" hidden>
    <span class="categories-empty-icon"><i class="bi bi-search"></i></span>
    <h3><%= t('categories.noMatchingCategories') %></h3>
    <p><%= t('categories.tryAnotherSearch') %></p>
  </div>
<% } %>
