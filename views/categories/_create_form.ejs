<div class="category-create-panel-inline" id="categoryCreatePanel" hidden>
  <div class="section-header category-create-header">
    <div>
      <p class="section-label">Create</p>
      <h2>New category</h2>
    </div>
  </div>

  <form class="category-form" method="POST" action="/categories/create" id="categoryCreateForm">
    <input type="hidden" name="redirectTab" id="categoryRedirectTabInput" value="<%= typeof activeTab === 'string' ? activeTab : 'expense' %>" />
    <input type="hidden" name="redirectQuery" value="<%= currentSearch %>" />

    <div class="category-form-grid">
      <div class="form-group">
        <label class="form-label">Type</label>
        <div class="form-toggle-group">
          <button type="button" class="form-toggle-btn is-active" data-toggle-target="type" data-toggle-value="expense">Expense</button>
          <button type="button" class="form-toggle-btn" data-toggle-target="type" data-toggle-value="income">Income</button>
        </div>
        <input type="hidden" id="categoryType" name="type" value="expense" />
      </div>

      <div class="form-group">
        <label class="form-label">Scope</label>
        <div class="form-toggle-group <%= family ? '' : 'is-single' %>">
          <button type="button" class="form-toggle-btn is-active" data-toggle-target="scope" data-toggle-value="personal">Personal</button>
          <% if (family) { %>
            <button type="button" class="form-toggle-btn" data-toggle-target="scope" data-toggle-value="family">Family</button>
          <% } %>
        </div>
        <input type="hidden" id="categoryScope" name="scope" value="personal" />
      </div>

      <div class="form-group category-form-grid-wide">
        <label class="form-label" for="categoryName">Category name</label>
        <input class="form-input" id="categoryName" name="name" type="text" placeholder="For example: Groceries, Salary, Transport" required />
      </div>
    </div>

    <div class="category-form-tools-grid">
      <div class="category-form-preview">
        <span class="category-preview-icon" id="selectedCategoryIconPreview" style="background-color: rgba(239, 68, 68, 0.16); color: #ef4444;">
          <i class="bi bi-cart3"></i>
        </span>

        <div class="category-preview-text">
          <strong id="selectedCategoryNamePreview">New category</strong>
          <div class="category-preview-meta">
            <span class="category-meta-pill" id="categoryModeBadge">Expense</span>
            <span class="category-meta-pill category-meta-pill--soft" id="categoryScopeBadge">Personal</span>
          </div>
        </div>
      </div>

      <div class="category-tools-side">
        <div class="form-group">
          <div class="category-colors-compact-row">
            <div class="category-color-swatches-box">
              <div class="category-color-swatches">
                <% colorOptions.forEach((color, index) => { %>
                  <button
                    class="category-color-swatch <%= index === 0 ? 'is-active' : '' %>"
                    type="button"
                    style="background-color: <%= color %>;"
                    aria-label="<%= color %>"
                    data-color-value="<%= color %>"
                  ></button>
                <% }) %>
              </div>
            </div>

            <div class="category-custom-color-box">
              <input class="category-color-picker category-color-picker--rounded" id="customColor" name="color" type="color" value="#ef4444" />
              <span class="category-color-value" id="categoryColorValue">#EF4444</span>
            </div>
          </div>
        </div>
      </div>

      <div class="category-icon-picker-wrap">
        <div class="form-group category-form-grid-wide">
          <div class="category-edit-icons-grid category-create-icons-grid" data-create-icon-grid>
            <% iconOptions.forEach((iconName, index) => { %>
              <div class="category-edit-icon-cell">
                <button
                  type="button"
                  class="category-edit-icon-btn category-create-icon-btn <%= index === 0 ? 'is-active' : '' %>"
                  data-icon-value="<%= iconName %>"
                  title="<%= iconName %>"
                >
                  <i class="bi bi-<%= iconName %>"></i>
                </button>
              </div>
            <% }) %>
          </div>

          <input type="hidden" name="icon" id="selectedCategoryIconInput" value="cart3" />
        </div>
      </div>
    </div>

    <div class="category-editor-actions">
      <button class="btn btn-primary" type="submit">Save category</button>
      <button class="btn btn-secondary" type="reset" id="categoryFormResetButton">Reset</button>
    </div>
  </form>
</div>