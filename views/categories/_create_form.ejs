<% /* Inline category creation form used by the categories page. */ %>
<div class="category-create-panel-inline" id="categoryCreatePanel" hidden>
  <div class="section-header category-create-header">
    <div>
      <p class="section-label"><%= t('categories.create') %></p>
      <h2><%= t('categories.newCategory') %></h2>
    </div>
  </div>

  <form class="category-form" method="POST" action="/categories/create" id="categoryCreateForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="redirectTab" id="categoryRedirectTabInput" value="<%= typeof activeTab === 'string' ? activeTab : 'all' %>" />
    <input type="hidden" name="redirectQuery" value="<%= currentSearch %>" />

    <div class="row g-3 align-items-end category-create-top-row">
      <div class="col-md-6 col-xl-3">
        <div class="form-group">
          <label class="form-label"><%= t('categories.type') %></label>

          <div class="form-toggle-group">
            <button type="button" class="form-toggle-btn is-active" data-toggle-target="type" data-toggle-value="expense">
              <%= t('categories.expense') %>
            </button>

            <button type="button" class="form-toggle-btn" data-toggle-target="type" data-toggle-value="income">
              <%= t('categories.income') %>
            </button>
          </div>

          <input type="hidden" id="categoryType" name="type" value="expense" />
        </div>
      </div>

      <div class="col-md-6 col-xl-9">
        <div class="form-group category-name-group">
          <label class="form-label" for="categoryName"><%= t('categories.categoryName') %></label>

          <input
            class="form-control rounded-3 category-name-input"
            id="categoryName"
            name="name"
            type="text"
            placeholder="<%= t('categories.namePlaceholder') %>"
            required
          />
        </div>
      </div>
    </div>

    <div class="row g-3 align-items-stretch category-create-workspace">
      <div class="col-lg-4 category-create-preview-col">
        <div class="category-form-preview h-100">
          <span
            class="category-preview-icon"
            id="selectedCategoryIconPreview"
            style="background-color: rgba(239, 68, 68, 0.16); color: #ef4444;"
          >
            <i class="bi bi-cart3"></i>
          </span>

          <div class="category-preview-text">
            <strong id="selectedCategoryNamePreview"><%= t('categories.newCategory') %></strong>

            <div class="category-preview-meta">
              <span class="category-meta-pill" id="categoryModeBadge"><%= t('categories.expense') %></span>
              <span class="category-meta-pill category-meta-pill--soft" id="categoryScopeBadge"><%= family ? t('categories.familyWorkspace') : t('categories.personalWorkspace') %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4 category-create-color-col">
        <div class="category-create-tool-card h-100">
          <label class="form-label" for="customColor"><%= t('categories.chooseAnyColor') %></label>

          <div class="category-color-swatches">
            <% colorOptions.forEach((color, index) => { %>
              <button
                class="category-color-swatch <%= index === 0 ? 'is-active' : '' %>"
                type="button"
                style="background-color: <%= color %>;"
                aria-label="<%= color %>"
                data-color-value="<%= color %>"
              ></button>
            <% }) %>
          </div>

          <div class="category-custom-color-box mt-3">
            <input
              class="category-color-picker"
              id="customColor"
              name="color"
              type="color"
              value="#ef4444"
            />

            <span class="category-color-value" id="categoryColorValue">#EF4444</span>
          </div>
        </div>
      </div>

      <div class="col-lg-4 category-create-icons-col">
        <div class="category-create-tool-card h-100">
          <label class="form-label"><%= t('categories.icon') %></label>

          <div class="category-edit-icons-grid category-create-icons-grid" data-create-icon-grid>
            <% iconOptions.forEach((iconName, index) => { %>
              <div class="category-edit-icon-cell">
                <button
                  type="button"
                  class="category-edit-icon-btn category-create-icon-btn <%= index === 0 ? 'is-active' : '' %>"
                  data-icon-value="<%= iconName %>"
                  title="<%= iconName %>"
                >
                  <i class="bi bi-<%= iconName %>"></i>
                </button>
              </div>
            <% }) %>
          </div>

          <input type="hidden" name="icon" id="selectedCategoryIconInput" value="cart3" />
        </div>
      </div>
    </div>

    <div class="category-dashboard-feature-card">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" role="switch" id="categoryDashboardFeatured" name="dashboardFeatured" value="1" />
        <label class="form-check-label" for="categoryDashboardFeatured">
          <strong><%= t('categories.addToDashboard') %></strong>
          <span><%= t('categories.addToDashboardDescription') %></span>
        </label>
      </div>
    </div>

    <div class="category-editor-actions">
      <button class="btn btn-primary rounded-pill px-4" type="submit">
        <%= t('categories.saveCategory') %>
      </button>

      <button class="btn btn-secondary rounded-pill px-4" type="reset" id="categoryFormResetButton">
        <%= t('categories.reset') %>
      </button>
    </div>
  </form>
</div>
