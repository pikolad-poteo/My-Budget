<form class="category-editor-body" method="POST" action="/categories/<%= category.id %>/update">
  <input type="hidden" name="redirectTab" value="<%= typeof activeTab === 'string' ? activeTab : 'expense' %>" />
  <input type="hidden" name="redirectQuery" value="<%= currentSearch %>" />

  <div class="category-edit-grid">
    <div class="form-group">
      <label class="form-label" for="<%= typeKey %>-name-<%= category.id %>">Name</label>
      <input class="form-input" id="<%= typeKey %>-name-<%= category.id %>" name="name" type="text" value="<%= category.name %>" required />
    </div>

    <div class="form-group">
      <label class="form-label" for="<%= typeKey %>-type-<%= category.id %>">Type</label>
      <select class="form-input form-select" id="<%= typeKey %>-type-<%= category.id %>" name="type" required>
        <option value="expense" <%= category.type === 'expense' ? 'selected' : '' %>>Expense</option>
        <option value="income" <%= category.type === 'income' ? 'selected' : '' %>>Income</option>
      </select>
    </div>

    <div class="form-group">
      <label class="form-label" for="<%= typeKey %>-color-<%= category.id %>">Color</label>
      <input class="category-color-picker category-color-picker--rounded category-edit-color-input" id="<%= typeKey %>-color-<%= category.id %>" name="color" type="color" value="<%= category.color || '#6c757d' %>" />
    </div>

    <div class="form-group category-edit-grid-wide">
      <label class="form-label">Icon</label>
      <div class="category-edit-icons-grid" data-edit-icon-grid>
        <% iconOptions.forEach((iconName) => { %>
          <div class="category-edit-icon-cell">
            <button
              type="button"
              class="category-edit-icon-btn <%= (category.icon || 'tag') === iconName ? 'is-active' : '' %>"
              data-edit-icon-value="<%= iconName %>"
              title="<%= iconName %>"
            >
              <i class="bi bi-<%= iconName %>"></i>
            </button>
          </div>
        <% }) %>
      </div>
      <input type="hidden" name="icon" value="<%= category.icon || 'tag' %>" data-edit-icon-input />
    </div>
  </div>

  <div class="category-edit-actions">
    <button type="submit" class="category-save-btn">Save</button>

    <button
      type="submit"
      class="category-delete-btn"
      formaction="/categories/<%= category.id %>/delete"
      formmethod="POST"
      onclick="return confirm('Delete this category?')"
    >
      Delete
    </button>
  </div>
</form>