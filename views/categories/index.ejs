<%- include('../partials/header') %>

<%
  const expenseCount = expenseCategories.length;
  const incomeCount = incomeCategories.length;
  const totalCount = expenseCount + incomeCount;
  const currentSearch = typeof searchTerm === 'string' ? searchTerm : '';

  function hexToRgba(hex, alpha) {
    if (!hex) return `rgba(108, 117, 125, ${alpha})`;

    const normalized = hex.replace('#', '');
    const value = normalized.length === 3
      ? normalized.split('').map((char) => char + char).join('')
      : normalized;

    const r = parseInt(value.substring(0, 2), 16);
    const g = parseInt(value.substring(2, 4), 16);
    const b = parseInt(value.substring(4, 6), 16);

    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  function getScopeLabel(category) {
    return category.family_id ? 'Family' : 'Personal';
  }

  function getCategoryHint(category) {
    return category.family_id
      ? 'Shared category for family members'
      : 'Visible only in your personal budget';
  }

  function getTypeLabel(type) {
    return type === 'income' ? 'Income' : 'Expense';
  }
%>

<section class="container categories-shell">
  <% if (errorMessage) { %>
    <div class="alert alert-danger mb-4" role="alert">
      <%= errorMessage %>
    </div>
  <% } %>

  <% if (successMessage) { %>
    <div class="alert alert-success mb-4" role="alert">
      <%= successMessage %>
    </div>
  <% } %>

  <section class="section-card categories-overview-panel">
    <div class="categories-toolbar-main">
      <div class="categories-toolbar-copy">
        <p class="section-label">Management</p>
        <h2>Category overview</h2>
        <p class="categories-toolbar-text">
          Create and edit expense or income categories for yourself<%= family ? ' and your family' : '' %>.
        </p>
      </div>

      <div class="categories-toolbar-actions">
        <button
          type="button"
          class="btn btn-primary"
          id="toggleCategoryCreateButton"
          aria-expanded="false"
          aria-controls="categoryCreatePanel"
        >
          <i class="bi bi-plus-lg me-2"></i>
          <span id="toggleCategoryCreateButtonText">Add category</span>
        </button>
      </div>
    </div>

    <div class="categories-stats">
      <article class="categories-stat-chip">
        <span class="categories-stat-value"><%= totalCount %></span>
        <span class="categories-stat-label">Total</span>
      </article>

      <article class="categories-stat-chip">
        <span class="categories-stat-value"><%= expenseCount %></span>
        <span class="categories-stat-label">Expense</span>
      </article>

      <article class="categories-stat-chip">
        <span class="categories-stat-value"><%= incomeCount %></span>
        <span class="categories-stat-label">Income</span>
      </article>

      <article class="categories-stat-chip">
        <span class="categories-stat-value"><%= family ? 'On' : 'Off' %></span>
        <span class="categories-stat-label">Family mode</span>
      </article>
    </div>

    <%- include('./_create_form', {
      activeTab,
      currentSearch,
      family,
      colorOptions,
      iconOptions
    }) %>
  </section>

  <section class="section-card categories-section">
    <div class="categories-section-top">
      <div class="categories-switcher">
        <button type="button" class="categories-switcher-btn is-active" data-category-tab="expense" data-is-default-tab="true">
          Expenses
          <span><%= expenseCount %></span>
        </button>

        <button type="button" class="categories-switcher-btn" data-category-tab="income">
          Income
          <span><%= incomeCount %></span>
        </button>
      </div>

      <form class="categories-search" method="GET" action="/categories">
        <input type="hidden" name="tab" id="categoriesSearchTabInput" value="<%= typeof activeTab === 'string' ? activeTab : 'expense' %>" />

        <div class="categories-search-input-wrap">
          <i class="bi bi-search"></i>
          <input
            class="categories-search-input"
            type="search"
            name="q"
            value="<%= currentSearch %>"
            placeholder="Search category by name"
            aria-label="Search category by name"
          />
        </div>

        <button class="btn btn-secondary categories-search-btn" type="submit">Search</button>

        <% if (currentSearch) { %>
          <a class="btn btn-outline-secondary categories-search-clear" href="/categories?tab=<%= typeof activeTab === 'string' ? activeTab : 'expense' %>">Clear</a>
        <% } %>
      </form>
    </div>

    <div class="categories-tab-panel is-active" data-category-panel="expense">
      <%- include('./_category_list', {
        categories: expenseCategories,
        activeTab,
        currentSearch,
        iconOptions,
        typeKey: 'expense',
        emptyTitle: 'No expense categories yet',
        emptyText: 'Create your first expense category using the button above.',
        addButtonTitle: 'Add expense category',
        addButtonText: 'Create one more expense card',
        hexToRgba,
        getCategoryHint,
        getScopeLabel,
        getTypeLabel
      }) %>
    </div>

    <div class="categories-tab-panel" data-category-panel="income">
      <%- include('./_category_list', {
        categories: incomeCategories,
        activeTab,
        currentSearch,
        iconOptions,
        typeKey: 'income',
        emptyTitle: 'No income categories yet',
        emptyText: 'Create your first income category using the button above.',
        addButtonTitle: 'Add income category',
        addButtonText: 'Create one more income card',
        hexToRgba,
        getCategoryHint,
        getScopeLabel,
        getTypeLabel
      }) %>
    </div>
  </section>
</section>

<script src="/js/categories.js"></script>

<%- include('../partials/footer') %>