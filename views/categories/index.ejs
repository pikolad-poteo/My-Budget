<% /* Categories page shell with shared overview, filters, create form and editable category lists. */ %>
<%- include('../partials/header') %>

<%
  const expenseCount = expenseCategories.length;
  const incomeCount = incomeCategories.length;
  const totalCount = expenseCount + incomeCount;
  const currentSearch = typeof searchTerm === 'string' ? searchTerm : '';

  function hexToRgba(hex, alpha) {
    if (!hex) return `rgba(108, 117, 125, ${alpha})`;

    const normalized = hex.replace('#', '');
    const value = normalized.length === 3
      ? normalized.split('').map((char) => char + char).join('')
      : normalized;

    const r = parseInt(value.substring(0, 2), 16);
    const g = parseInt(value.substring(2, 4), 16);
    const b = parseInt(value.substring(4, 6), 16);

    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  function getTypeLabel(type) {
    return type === 'income' ? t('categories.income') : t('categories.expense');
  }

  const normalizedActiveTab = typeof activeTab === 'string' ? activeTab : 'expense';
%>

<section class="container categories-shell">
  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-3 mb-4" role="alert">
      <%= errorMessage %>
    </div>
  <% } %>

  <% if (successMessage) { %>
    <div class="alert alert-success rounded-3 mb-4" role="alert">
      <%= successMessage %>
    </div>
  <% } %>

  <%- include('../partials/page-overview', {
    eyebrow: t('categories.management'),
    heading: t('categories.overviewTitle'),
    description: family ? t('categories.overviewDescriptionFamily') : t('categories.overviewDescriptionPersonal'),
    buttonId: 'toggleCategoryCreateButton',
    buttonTextId: 'toggleCategoryCreateButtonText',
    controlsId: 'categoryCreatePanel',
    buttonLabel: t('categories.addCategory'),
    stats: [
      { value: totalCount, label: t('categories.total') },
      { value: expenseCount, label: t('categories.expense') },
      { value: incomeCount, label: t('categories.income') },
      { value: family ? t('categories.on') : t('categories.off'), label: t('categories.familyMode') }
    ],
    createContent: include('./_create_form', {
      activeTab,
      currentSearch,
      family,
      colorOptions,
      iconOptions
    })
  }) %>

  <section class="card border-0 shadow-sm rounded-4 section-card categories-section">
    <div class="card-body p-4">
      <div class="category-section-header">
        <p class="section-label mb-1"><%= t('categories.management') %></p>
        <h2><%= t('categories.title') %></h2>
      </div>

      <div class="categories-toolbar">
        <div class="categories-toolbar-left">
          <div class="categories-view-switcher" aria-label="<%= t('categories.viewMode') %>">
            <button type="button" class="categories-view-btn is-active" data-category-view="cards">
              <i class="bi bi-grid"></i>
              <span><%= t('categories.cards') %></span>
            </button>
            <button type="button" class="categories-view-btn" data-category-view="list">
              <i class="bi bi-list-ul"></i>
              <span><%= t('categories.list') %></span>
            </button>
          </div>

          <div class="categories-switcher">
            <button
              type="button"
              class="categories-switcher-btn <%= normalizedActiveTab === 'expense' ? 'is-active' : '' %>"
              data-category-tab="expense"
              data-is-default-tab="true"
            >
              <%= t('categories.expenses') %>
              <span><%= expenseCount %></span>
            </button>

            <button
              type="button"
              class="categories-switcher-btn <%= normalizedActiveTab === 'income' ? 'is-active' : '' %>"
              data-category-tab="income"
            >
              <%= t('categories.income') %>
              <span><%= incomeCount %></span>
            </button>
          </div>
        </div>

        <form class="categories-search" id="categoriesLiveSearchForm" autocomplete="off">
          <input type="hidden" name="tab" id="categoriesSearchTabInput" value="<%= normalizedActiveTab %>" />

          <div class="input-group categories-bootstrap-search">
            <span class="input-group-text bg-white border-end-0">
              <i class="bi bi-search"></i>
            </span>

            <input
              class="form-control border-start-0"
              type="search"
              name="q"
              id="categoriesLiveSearchInput"
              value="<%= currentSearch %>"
              placeholder="<%= t('categories.searchPlaceholder') %>"
              aria-label="<%= t('categories.searchPlaceholder') %>"
              data-live-category-search
            />

            <button
              class="btn btn-outline-secondary px-4 categories-search-clear"
              type="button"
              id="categoriesLiveSearchClear"
              <%= currentSearch ? '' : 'hidden' %>
            >
              <%= t('categories.clear') %>
            </button>
          </div>
        </form>
      </div>

      <div class="categories-tab-panel <%= normalizedActiveTab === 'expense' ? 'is-active' : '' %>" data-category-panel="expense">
        <%- include('./_category_list', {
          categories: expenseCategories,
          activeTab,
          currentSearch,
          iconOptions,
          colorOptions,
          typeKey: 'expense',
          emptyTitle: t('categories.noExpenseCategoriesYet'),
          emptyText: t('categories.createFirstExpenseCategory'),
          addButtonTitle: t('categories.addCategory'),
          addButtonText: t('categories.clickToCreate'),
          hexToRgba,
          getTypeLabel
        }) %>
      </div>

      <div class="categories-tab-panel <%= normalizedActiveTab === 'income' ? 'is-active' : '' %>" data-category-panel="income">
        <%- include('./_category_list', {
          categories: incomeCategories,
          activeTab,
          currentSearch,
          iconOptions,
          colorOptions,
          typeKey: 'income',
          emptyTitle: t('categories.noIncomeCategoriesYet'),
          emptyText: t('categories.createFirstIncomeCategory'),
          addButtonTitle: t('categories.addCategory'),
          addButtonText: t('categories.clickToCreate'),
          hexToRgba,
          getTypeLabel
        }) %>
      </div>
    </div>
  </section>
</section>

<script>
  window.categoryI18n = <%- JSON.stringify({
    addCategory: t('categories.addCategory'),
    hideCategoryForm: t('categories.hideCategoryForm'),
    newCategory: t('categories.newCategory'),
    income: t('categories.income'),
    expense: t('categories.expense'),
    family: t('categories.family'),
    personal: t('categories.personal')
  }).replace(/</g, '\\u003c') %>;
</script>
<script src="/js/categories.js"></script>

<%- include('../partials/footer') %>
