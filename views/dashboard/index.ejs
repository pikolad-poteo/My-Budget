<%- include('../partials/header') %>

<section class="container page-heading">
  <div>
    <p class="eyebrow">Overview</p>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-text">
      Main page with balance summary, category analytics and quick actions.
    </p>
  </div>
</section>

<section class="container cards-grid">
  <article class="info-card">
    <h2>Total balance</h2>
    <p class="card-value">0.00</p>
    <p class="card-text">Balance summary will be connected after database setup.</p>
  </article>

  <article class="info-card">
    <h2>Total income</h2>
    <p class="card-value">0.00</p>
    <p class="card-text">Income analytics will appear here in future updates.</p>
  </article>

  <article class="info-card">
    <h2>Total expenses</h2>
    <p class="card-value">0.00</p>
    <p class="card-text">Expense analytics will be displayed after transactions integration.</p>
  </article>
</section>

<section class="container section-block">
  <div class="section-card">
    <div class="section-header">
      <h2>Quick actions</h2>
    </div>

    <div class="actions-grid">
      <a href="/categories" class="action-card">
        <h3>Manage categories</h3>
        <p>Create income and expense categories.</p>
      </a>

      <a href="/transactions" class="action-card">
        <h3>View transactions</h3>
        <p>Open transaction history and filters.</p>
      </a>

      <a href="/wishlist" class="action-card">
        <h3>Open wishlist</h3>
        <p>Plan future purchases and goals.</p>
      </a>

      <a href="/calendar" class="action-card">
        <h3>Open calendar</h3>
        <p>Manage events and reminders.</p>
      </a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>