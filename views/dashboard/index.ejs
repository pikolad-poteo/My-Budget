<% /* Dashboard page that presents budget summary cards, charts and recent activity sections. */ %>
<%- include('../partials/header') %>

<%
  const data = dashboard || {};
  const summary = data.summary || {};
  const period = data.period || {};
  const analytics = data.analytics || {};
  const budgetHealth = analytics.budgetHealth || {};
  const wishlist = data.wishlist || {};
  const wishlistGoals = Array.isArray(wishlist.goals) ? wishlist.goals : [];
  const formatMoney = (value) => `${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} €`;
  const formatSignedMoney = (value) => `${Number(value || 0) >= 0 ? '+ ' : '- '}${formatMoney(Math.abs(Number(value || 0)))}`;
  const formatPercent = (value) => `${Number(value || 0).toFixed(1)}%`;
  const safeJson = (value) => JSON.stringify(value || {}).replace(/</g, '\\u003c');
  const incomeChange = summary.incomeChange || { value: 0, direction: 'flat', label: t('dashboard.messages.noActivityYet'), isGood: true };
  const expenseChange = summary.expenseChange || { value: 0, direction: 'flat', label: t('dashboard.messages.noActivityYet'), isGood: true };
  const changeIcon = (change) => change.direction === 'down' ? 'bi-arrow-down' : change.direction === 'up' ? 'bi-arrow-up' : 'bi-dash';
  const changeClass = (change) => change.direction === 'flat' && Number(change.value || 0) === 0 ? 'is-muted' : (change.isGood === false ? 'is-danger' : 'is-good');
  const recentTransactions = Array.isArray(data.recentTransactions) ? data.recentTransactions : [];
  const categoryBreakdown = Array.isArray(data.categoryBreakdown) ? data.categoryBreakdown : [];
  const featuredCategories = Array.isArray(data.featuredCategories) ? data.featuredCategories : [];
  const categoryTotal = Number(data.categoryTotal || 0);
  const upcomingEvents = Array.isArray(data.upcomingEvents) ? data.upcomingEvents : [];
  const topCategory = data.topCategory || null;
  const healthScore = Number(budgetHealth.score || 0);
  const healthClass = healthScore >= 80 ? 'is-strong' : healthScore >= 55 ? 'is-stable' : healthScore > 0 ? 'is-risk' : 'is-empty';
  const canEditBudget = Boolean(data.canEditBudget);
  const dashboardI18n = {
    locale: t('dashboard.locale'),
    income: t('dashboard.income'),
    expenses: t('dashboard.expenses'),
    today: t('dashboard.today')
  };
%>

<section class="container dashboard-shell">
  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-4 mb-4" role="alert"><%= errorMessage %></div>
  <% } %>

  <section class="dashboard-overview-panel">
    <div class="dashboard-overview-copy">
      <p class="section-label mb-1"><%= t('dashboard.overview') %></p>
      <h2 class="h3 fw-bold mb-2"><%= t('dashboard.title') %></h2>
      <p class="overview-toolbar-text mb-0"><%= t('dashboard.description') %></p>
      <div class="dashboard-health-inline <%= healthClass %>" aria-label="<%= t('dashboard.budgetHealthScore') %>">
        <span class="dashboard-health-inline-title"><%= t('dashboard.budgetHealth') %></span>
        <strong><%= budgetHealth.score || 0 %>%</strong>
        <em><%= budgetHealth.status || t('dashboard.noDataYet') %></em>
        <button
          type="button"
          class="dashboard-health-info"
          data-bs-toggle="popover"
          data-bs-trigger="hover focus"
          data-bs-placement="top"
          data-bs-html="true"
          data-bs-title="<%= t('dashboard.aboutBudgetHealth') %>"
          data-bs-content="<%- t('dashboard.budgetHealthPopover') %>"
          aria-label="<%= t('dashboard.howBudgetHealthCalculated') %>"
        >
          <i class="bi bi-info"></i>
        </button>
      </div>
    </div>

    <div class="dashboard-overview-side">
      <% if (canEditBudget) { %>
        <a href="/transactions?create=1" class="btn btn-primary rounded-pill px-4 dashboard-add-transaction-btn">
          <i class="bi bi-plus-lg me-2"></i>
          <%= t('dashboard.addTransaction') %>
        </a>
      <% } %>


    </div>
  </section>

  <section class="dashboard-metrics-grid" aria-label="<%= t('dashboard.budgetSummary') %>">
    <article class="dashboard-metric-card">
      <div class="dashboard-metric-head">
        <span class="dashboard-metric-label"><%= t('dashboard.currentBalance') %></span>
        <span class="dashboard-metric-icon"><i class="bi bi-wallet2"></i></span>
      </div>
      <strong class="dashboard-metric-value"><%= formatMoney(summary.balance) %></strong>
      <span class="dashboard-metric-note"><%= t('dashboard.availableAcrossWorkspace') %></span>
    </article>

    <article class="dashboard-metric-card">
      <div class="dashboard-metric-head">
        <span class="dashboard-metric-label"><%= t('dashboard.income') %> <%= period.summaryLabel || t('dashboard.period.thisMonth') %></span>
        <span class="dashboard-metric-icon"><i class="bi bi-graph-up-arrow"></i></span>
      </div>
      <strong class="dashboard-metric-value"><%= formatMoney(summary.periodIncome) %></strong>
      <span class="dashboard-change <%= changeClass(incomeChange) %>">
        <i class="bi <%= changeIcon(incomeChange) %>"></i>
        <%= incomeChange.label %>
      </span>
    </article>

    <article class="dashboard-metric-card">
      <div class="dashboard-metric-head">
        <span class="dashboard-metric-label"><%= t('dashboard.expenses') %> <%= period.summaryLabel || t('dashboard.period.thisMonth') %></span>
        <span class="dashboard-metric-icon"><i class="bi bi-cart3"></i></span>
      </div>
      <strong class="dashboard-metric-value"><%= formatMoney(summary.periodExpenses) %></strong>
      <span class="dashboard-change <%= changeClass(expenseChange) %>">
        <i class="bi <%= changeIcon(expenseChange) %>"></i>
        <%= expenseChange.label %>
      </span>
    </article>

    <article class="dashboard-metric-card">
      <div class="dashboard-metric-head">
        <span class="dashboard-metric-label"><%= t('dashboard.savingsRate') %></span>
        <span class="dashboard-metric-icon"><i class="bi bi-bullseye"></i></span>
      </div>
      <strong class="dashboard-metric-value"><%= formatPercent(summary.savingsRate) %></strong>
      <span class="dashboard-metric-note"><%= t('dashboard.yourGoal') %>: 40%</span>
    </article>
  </section>

  <section class="dashboard-card dashboard-chart-card">
    <div class="dashboard-card-header dashboard-chart-header">
      <div>
        <h2><%= t('dashboard.cashFlowTrend') %></h2>
        <p><%= t('dashboard.cashFlowDescriptionPrefix') %> <%= data.periodLabel || t('dashboard.selectedPeriod') %><%= period.containsToday ? ' ' + t('dashboard.upToToday') : '' %>.</p>
      </div>

      <div class="dashboard-period-controls" aria-label="<%= t('dashboard.periodControls') %>">
        <a href="<%= period.previousUrl || '/dashboard' %>" class="dashboard-period-arrow" aria-label="<%= t('dashboard.previousPeriod') %>">
          <i class="bi bi-chevron-left"></i>
        </a>

        <span class="dashboard-period-label"><%= period.shortLabel || data.periodLabel || t('dashboard.currentPeriod') %></span>

        <a href="<%= period.nextUrl || '/dashboard' %>" class="dashboard-period-arrow" aria-label="<%= t('dashboard.nextPeriod') %>">
          <i class="bi bi-chevron-right"></i>
        </a>

        <div class="dashboard-period-tabs" role="group" aria-label="<%= t('dashboard.periodType') %>">
          <a href="<%= period.monthUrl || '/dashboard' %>" class="dashboard-period-tab <%= period.mode === 'month' ? 'is-active' : '' %>"><%= t('dashboard.month') %></a>
          <a href="<%= period.yearUrl || '/dashboard?mode=year' %>" class="dashboard-period-tab <%= period.mode === 'year' ? 'is-active' : '' %>"><%= t('dashboard.year') %></a>
        </div>
      </div>
    </div>

    <div class="dashboard-chart-wrap">
      <canvas id="cashFlowChart" aria-label="<%= t('dashboard.cashFlowTrendChart') %>"></canvas>
    </div>
  </section>

  <section class="dashboard-card dashboard-category-card">
    <div class="dashboard-card-header">
      <div>
        <h2><%= t('dashboard.expensesByCategory') %></h2>
        <p><%= t('dashboard.expensesByCategoryDescriptionPrefix') %> <%= data.periodLabel || t('dashboard.thisPeriod') %>.</p>
      </div>

      <% if (topCategory) { %>
        <span class="dashboard-top-category-pill">
          <%= t('dashboard.top') %>: <strong><%= topCategory.name %></strong>
        </span>
      <% } %>
    </div>

    <% if (categoryBreakdown.length) { %>
      <div class="dashboard-category-panel">
        <div class="dashboard-donut-area">
          <div class="dashboard-donut-wrap">
            <canvas id="categoryChart" aria-label="<%= t('dashboard.expensesByCategoryChart') %>"></canvas>
            <div class="dashboard-donut-center" aria-hidden="true">
              <strong><%= formatMoney(categoryTotal) %></strong>
              <span><%= t('dashboard.totalExpenses') %></span>
            </div>
          </div>
        </div>

        <div class="dashboard-category-list">
          <% categoryBreakdown.forEach(function (category) { %>
            <div class="dashboard-category-row">
              <span
                class="dashboard-category-chip"
                style="--category-color: <%= category.color %>;"
                aria-label="<%= category.name %> <%= t('dashboard.categoryIcon') %>"
              >
                <i class="<%= category.iconClass %>"></i>
              </span>
              <strong><%= category.name %></strong>
              <span><%= formatMoney(category.total) %></span>
              <small><%= formatPercent(category.percent) %></small>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="dashboard-featured-categories">
        <button
          class="dashboard-featured-toggle collapsed"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#dashboardFeaturedCategories"
          aria-expanded="false"
          aria-controls="dashboardFeaturedCategories"
        >
          <span><i class="bi bi-stars"></i> <%= t('dashboard.specialDashboardCategories') %></span>
          <small><%= featuredCategories.length %> <%= t('dashboard.marked') %></small>
          <i class="bi bi-chevron-down dashboard-featured-chevron"></i>
        </button>

        <div class="collapse" id="dashboardFeaturedCategories">
          <div class="dashboard-featured-body">
            <% if (featuredCategories.length) { %>
              <% featuredCategories.forEach(function (category) { %>
                <div class="dashboard-category-row dashboard-featured-row">
                  <span
                    class="dashboard-category-chip"
                    style="--category-color: <%= category.color %>;"
                    aria-label="<%= category.name %> special <%= t('dashboard.categoryIcon') %>"
                  >
                    <i class="<%= category.iconClass %>"></i>
                  </span>
                  <strong><%= category.name %></strong>
                  <span><%= formatMoney(category.total) %></span>
                  <small><%= formatPercent(category.percent) %></small>
                </div>
              <% }) %>
            <% } else { %>
              <div class="dashboard-featured-empty">
                <%= t('dashboard.featuredCategoriesEmpty') %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="dashboard-empty-state">
        <i class="bi bi-pie-chart"></i>
        <p><%= t('dashboard.noExpenseCategoriesPrefix') %> <%= data.periodLabel || t('dashboard.thisPeriod') %> <%= t('dashboard.noExpenseCategoriesSuffix') %></p>
      </div>
    <% } %>
  </section>

  <section class="dashboard-accordion" aria-label="<%= t('dashboard.details') %>">
    <article class="dashboard-accordion-item dashboard-transactions-card">
      <button
        class="dashboard-accordion-button collapsed"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#dashboardRecentTransactions"
        aria-expanded="false"
        aria-controls="dashboardRecentTransactions"
      >
        <span class="dashboard-accordion-icon"><i class="bi bi-receipt"></i></span>
        <span>
          <strong><%= t('dashboard.recentTransactions') %></strong>
          <small><%= t('dashboard.latestBudgetActivity') %></small>
        </span>
        <i class="bi bi-chevron-down dashboard-accordion-chevron"></i>
      </button>

      <div class="collapse" id="dashboardRecentTransactions">
        <div class="dashboard-accordion-body">
          <div class="dashboard-accordion-body-head">
            <span><%= t('dashboard.latestEntries') %></span>
            <a href="/transactions" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><%= t('dashboard.viewAll') %></a>
          </div>

          <% if (recentTransactions.length) { %>
            <div class="dashboard-transaction-list">
              <% recentTransactions.forEach(function (transaction) { %>
                <article class="dashboard-transaction-row">
                  <span class="dashboard-transaction-icon <%= transaction.type === 'income' ? 'is-income' : 'is-expense' %>">
                    <i class="<%= transaction.iconClass %>"></i>
                  </span>

                  <span class="dashboard-transaction-date"><%= transaction.dateLabel %></span>

                  <div class="dashboard-transaction-main">
                    <strong class="dashboard-transaction-title"><%= transaction.description %></strong>
                    <span class="dashboard-transaction-author"><%= t('dashboard.by') %> <%= transaction.actorName %></span>
                  </div>

                  <span
                    class="dashboard-category-chip"
                    style="--category-color: <%= transaction.categoryColor %>;"
                    data-bs-toggle="tooltip"
                    data-bs-placement="top"
                    title="<%= transaction.categoryName %>"
                    aria-label="<%= transaction.categoryName %> <%= t('dashboard.category') %>"
                  >
                    <i class="<%= transaction.categoryIconClass %>"></i>
                  </span>

                  <strong class="dashboard-transaction-amount <%= transaction.type === 'income' ? 'is-income' : 'is-expense' %>">
                    <%= formatSignedMoney(transaction.amount) %>
                  </strong>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="dashboard-empty-state">
              <i class="bi bi-receipt"></i>
              <p><%= t('dashboard.noTransactionsYet') %></p>
            </div>
          <% } %>
        </div>
      </div>
    </article>

    <article class="dashboard-accordion-item dashboard-events-card">
      <button
        class="dashboard-accordion-button collapsed"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#dashboardUpcomingEvents"
        aria-expanded="false"
        aria-controls="dashboardUpcomingEvents"
      >
        <span class="dashboard-accordion-icon"><i class="bi bi-calendar-event"></i></span>
        <span>
          <strong><%= t('dashboard.upcomingEvents') %></strong>
          <small><%= t('dashboard.nearestCalendarEvents') %></small>
        </span>
        <i class="bi bi-chevron-down dashboard-accordion-chevron"></i>
      </button>

      <div class="collapse" id="dashboardUpcomingEvents">
        <div class="dashboard-accordion-body">
          <div class="dashboard-accordion-body-head">
            <span><%= t('dashboard.calendarPreview') %></span>
            <a href="/calendar" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><%= t('dashboard.viewCalendar') %></a>
          </div>

          <% if (upcomingEvents.length) { %>
            <div class="dashboard-events-list">
              <% upcomingEvents.forEach(function (event) { %>
                <article class="dashboard-event-row" style="--event-color: <%= event.color %>;">
                  <span class="dashboard-event-date"><%= event.dateLabel %></span>
                  <div>
                    <strong><%= event.title %></strong>
                    <p><i class="bi bi-clock"></i> <%= event.timeLabel %> · <%= event.description %></p>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="dashboard-empty-state">
              <i class="bi bi-calendar-event"></i>
              <p><%= t('dashboard.noUpcomingEventsYet') %></p>
            </div>
          <% } %>
        </div>
      </div>
    </article>

    <article class="dashboard-accordion-item dashboard-wishlist-card">
      <button
        class="dashboard-accordion-button collapsed"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#dashboardWishlistImpact"
        aria-expanded="false"
        aria-controls="dashboardWishlistImpact"
      >
        <span class="dashboard-accordion-icon"><i class="bi bi-heart"></i></span>
        <span>
          <strong><%= t('dashboard.wishlistImpact') %></strong>
          <small><%= t('dashboard.plannedGoalsDescription') %></small>
        </span>
        <i class="bi bi-chevron-down dashboard-accordion-chevron"></i>
      </button>

      <div class="collapse" id="dashboardWishlistImpact">
        <div class="dashboard-accordion-body">
          <div class="dashboard-accordion-body-head">
            <span><%= t('dashboard.goalsPreview') %></span>
            <a href="/wishlist" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><%= t('dashboard.viewWishlist') %></a>
          </div>

          <div class="dashboard-wishlist-summary">
            <div><span><%= t('dashboard.plannedValue') %></span><strong><%= formatMoney(wishlist.plannedTotal) %></strong></div>
            <div><span><%= t('dashboard.boughtItems') %></span><strong><%= wishlist.boughtCount || 0 %> / <%= wishlist.totalCount || 0 %></strong></div>
            <div><span><%= t('dashboard.balanceAfterGoals') %></span><strong><%= formatMoney(wishlist.afterBalance) %></strong></div>
          </div>

          <% if (wishlistGoals.length) { %>
            <div class="dashboard-wishlist-goals">
              <% wishlistGoals.forEach(function (goal) { %>
                <article class="dashboard-wishlist-goal">
                  <% if (goal.imageUrl) { %>
                    <img src="<%= goal.imageUrl %>" alt="<%= goal.title %> <%= t('dashboard.image') %>" />
                  <% } else { %>
                    <span class="dashboard-wishlist-placeholder"><i class="bi bi-gift"></i></span>
                  <% } %>
                  <div>
                    <strong><%= goal.title %></strong>
                    <p><%= formatMoney(goal.amount) %></p>
                    <% if (goal.desiredDate) { %>
                      <small><i class="bi bi-calendar3"></i> <%= goal.desiredDate %></small>
                    <% } %>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="dashboard-empty-state">
              <i class="bi bi-heart"></i>
              <p><%= t('dashboard.noPlannedWishlistGoalsYet') %></p>
            </div>
          <% } %>
        </div>
      </div>
    </article>
  </section>
</section>

<script type="application/json" id="dashboardChartData"><%- safeJson(data.charts) %></script>
<script type="application/json" id="dashboardI18nData"><%- safeJson(dashboardI18n) %></script>
<script src="/vendor/chart.js/chart.umd.js"></script>
<script src="/js/dashboard.js"></script>

<%- include('../partials/footer') %>
