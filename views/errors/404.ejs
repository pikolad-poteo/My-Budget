<% /* Friendly not-found page for unknown routes. */ %>
<%- include('../partials/header') %>

<section class="container auth-section">
  <div class="auth-card text-center">
    <p class="eyebrow">404</p>
    <h1 class="page-title"><%= t('errors.notFound.title') %></h1>
    <p class="page-text"><%= t('errors.notFound.description') %></p>

    <div class="hero-actions justify-content-center">
      <a class="btn btn-primary rounded-pill px-4" href="<%= currentUser ? '/dashboard' : '/login' %>">
        <%= currentUser ? t('errors.actions.backToDashboard') : t('errors.actions.backToLogin') %>
      </a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
