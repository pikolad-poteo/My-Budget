<% /* Family action panel for create, leave, ownership and delete workflows. */ %>
<div class="family-sidebar-stack">
  <div class="card family-card family-invite-card">
    <div class="card-body">
      <div class="family-section-header">
        <div>
          <p class="section-label"><%= t('family.invitation') %></p>
          <h2><%= t('family.addUser') %></h2>
        </div>
      </div>

      <% if (familyPermissions.canManageMembers) { %>
        <form action="/family/members/add" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label" for="email"><%= t('family.emailAddress') %></label>
            <input class="form-control rounded-3" id="email" name="email" type="email" placeholder="<%= t('family.registeredUserEmail') %>" required />
          </div>

          <div class="mb-3">
            <label class="form-label" for="role"><%= t('family.role') %></label>
            <select class="form-select rounded-3" id="role" name="role">
              <option value="viewer"><%= t('family.roleOptions.viewer') %></option>
              <option value="editor"><%= t('family.roleOptions.editor') %></option>
              <option value="owner"><%= t('family.roleOptions.owner') %></option>
            </select>
          </div>

          <button class="btn btn-primary rounded-pill px-4 w-100" type="submit">
            <%= t('family.addMember') %>
          </button>
        </form>
      <% } else { %>
        <p class="family-sidebar-note mt-0">
          <%= t('family.ownerOnlyMemberManagement') %>
        </p>
      <% } %>
    </div>
  </div>

  <div class="card family-card family-settings-card">
    <div class="card-body">
      <div class="family-section-header">
        <div>
          <p class="section-label"><%= t('family.settings') %></p>
          <h2><%= t('family.familyProfile') %></h2>
        </div>
      </div>

      <% if (familyPermissions.canManageFamily) { %>
        <form action="/family/update" method="POST" class="mb-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="form-label" for="familyName"><%= t('family.familyName') %></label>
          <div class="family-inline-form">
            <input class="form-control rounded-3" id="familyName" name="familyName" type="text" value="<%= currentFamily.name %>" required />
            <button class="btn btn-primary rounded-pill px-4" type="submit"><%= t('family.save') %></button>
          </div>
        </form>

        <form action="/family/avatar?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="form-label" for="avatar"><%= t('family.familyAvatar') %></label>
          <input class="form-control rounded-3 mb-3" id="avatar" name="avatar" type="file" accept="image/*" />
          <button class="btn btn-secondary rounded-pill px-4 w-100" type="submit">
            <%= t('family.updateAvatar') %>
          </button>
        </form>
      <% } else { %>
        <p class="family-sidebar-note mt-0">
          <%= t('family.ownerOnlyFamilyProfile') %>
        </p>
      <% } %>
    </div>
  </div>

  <div class="card family-card family-permissions-card">
    <div class="card-body">
      <div class="family-section-header">
        <div>
          <p class="section-label"><%= t('family.permissions') %></p>
          <h2><%= t('family.accessSummary') %></h2>
        </div>
      </div>

      <ul class="family-permissions-list">
        <li><strong><%= t('family.roles.owner') %></strong> — <%= t('family.permissionsOwnerShort') %></li>
        <li><strong><%= t('family.roles.editor') %></strong> — <%= t('family.permissionsEditorShort') %></li>
        <li><strong><%= t('family.roles.viewer') %></strong> — <%= t('family.permissionsViewerShort') %></li>
      </ul>
    </div>
  </div>

  <div class="card family-card family-danger-card">
    <div class="card-body">
      <div class="family-section-header">
        <div>
          <p class="section-label"><%= t('family.dangerZone') %></p>
          <h2><%= t('family.leaveOrDelete') %></h2>
        </div>
      </div>

      <form action="/family/leave" method="POST" class="mb-4" onsubmit="return confirm(<%- JSON.stringify(t('family.confirmLeaveFamily')) %>);">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <p class="family-sidebar-note mt-0">
          <%= t('family.lastOwnerTransferHint') %>
        </p>
        <button class="btn btn-secondary rounded-pill w-100" type="submit">
          <%= t('family.leaveFamily') %>
        </button>
      </form>

      <% if (familyPermissions.canDeleteFamily) { %>
        <form action="/family/delete" method="POST" onsubmit="return confirm(<%- JSON.stringify(t('family.confirmDeleteFamily')) %>);">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <p class="family-sidebar-note mt-0">
            <%= t('family.deleteSidebarNote') %>
          </p>
          <input class="form-control rounded-3 mb-3" name="confirmation" type="text" placeholder="<%= t('family.typeDelete') %>" required />
          <button class="btn btn-danger rounded-pill w-100" type="submit">
            <%= t('family.deleteFamily') %>
          </button>
        </form>
      <% } else { %>
        <p class="family-sidebar-note mt-0">
          <%= t('family.onlyOwnersDeleteFamily') %>
        </p>
      <% } %>
    </div>
  </div>
</div>
