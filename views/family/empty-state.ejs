<% /* Personal-mode empty state shown when the user is not connected to a family workspace. */ %>
<%
  const personalStats = typeof personalWorkspaceStats !== 'undefined' && personalWorkspaceStats ? personalWorkspaceStats : { total: 0 };
  const hasPersonalData = Number(personalStats.total || 0) > 0;
%>

<div class="row g-4 align-items-stretch">
  <div class="col-lg-8">
    <div class="card family-card family-empty-card h-100">
      <div class="card-body">
        <div class="family-section-header family-empty-header">
          <div>
            <p class="section-label"><%= t('family.personalWorkspace') %></p>
            <h2><%= t('family.usingAlone') %></h2>
          </div>
          <span class="family-personal-badge"><%= t('family.singleUser') %></span>
        </div>

        <p class="family-description mb-4">
          <%= t('family.personalWorkspaceDescription') %>
        </p>

        <div class="family-personal-summary-grid mb-4">
          <div class="family-personal-summary-item">
            <span><%= t('family.categories') %></span>
            <strong><%= personalStats.categories || 0 %></strong>
          </div>
          <div class="family-personal-summary-item">
            <span><%= t('family.transactions') %></span>
            <strong><%= personalStats.transactions || 0 %></strong>
          </div>
          <div class="family-personal-summary-item">
            <span><%= t('family.wishlist') %></span>
            <strong><%= personalStats['wishlist items'] || 0 %></strong>
          </div>
          <div class="family-personal-summary-item">
            <span><%= t('family.calendar') %></span>
            <strong><%= personalStats['calendar events'] || 0 %></strong>
          </div>
        </div>

        <div class="family-info-box mb-4">
          <i class="bi bi-info-circle"></i>
          <div>
            <strong><%= t('family.createFamilyInfoTitle') %></strong>
            <p><%= t('family.createFamilyInfoText') %></p>
          </div>
        </div>

        <button class="btn btn-primary rounded-pill px-4" type="button" data-bs-toggle="modal" data-bs-target="#createFamilyModal">
          <%= t('family.createFamily') %>
        </button>
      </div>
    </div>
  </div>

  <aside class="col-lg-4">
    <div class="card family-card family-access-card h-100">
      <div class="card-body">
        <div class="family-section-header">
          <div>
            <p class="section-label"><%= t('family.howItWorks') %></p>
            <h2><%= t('family.workspaceRules') %></h2>
          </div>
        </div>

        <div class="family-rules-list">
          <div class="family-rule-item">
            <strong><%= t('family.personalMode') %></strong>
            <p><%= t('family.personalModeText') %></p>
          </div>
          <div class="family-rule-item">
            <strong><%= t('family.createFamily') %></strong>
            <p><%= t('family.createFamilyRuleText') %></p>
          </div>
          <div class="family-rule-item">
            <strong><%= t('family.familyMode') %></strong>
            <p><%= t('family.familyModeText') %></p>
          </div>
        </div>
      </div>
    </div>
  </aside>
</div>

<div class="modal fade" id="createFamilyModal" tabindex="-1" aria-labelledby="createFamilyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content family-modal-content">
      <div class="modal-header border-0 pb-0">
        <div>
          <p class="section-label mb-1"><%= t('family.createWorkspace') %></p>
          <h2 class="modal-title family-modal-title" id="createFamilyModalLabel"><%= t('family.createFamilyWorkspace') %></h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('family.close') %>"></button>
      </div>

      <form action="/family/create" method="POST" class="family-preserve-scroll-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body pt-3">
          <div class="family-warning-box mb-3">
            <i class="bi bi-arrow-left-right"></i>
            <div>
              <strong><%= t('family.personalDataMovedTitle') %></strong>
              <p>
                <% if (hasPersonalData) { %>
                  <%= t('family.personalRecordsPrefix') %> <%= personalStats.total %> <%= t('family.personalRecordsSuffix') %>
                <% } else { %>
                  <%= t('family.noPersonalRecordsYet') %>
                <% } %>
              </p>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="familyName"><%= t('family.familyName') %></label>
            <input class="form-control rounded-pill" id="familyName" name="familyName" type="text" placeholder="<%= t('family.enterFamilyName') %>" required />
          </div>

          <label class="family-checkbox-confirm">
            <input type="checkbox" required>
            <span><%= t('family.createFamilyConfirmText') %></span>
          </label>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal"><%= t('family.cancel') %></button>
          <button class="btn btn-primary rounded-pill px-4" type="submit"><%= t('family.createFamily') %></button>
        </div>
      </form>
    </div>
  </div>
</div>
