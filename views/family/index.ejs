<%- include('../partials/header') %>

<%
  const currentFamily = typeof family !== 'undefined' ? family : null;
  const familyMembers = typeof members !== 'undefined' ? members : [];
  const pageError = typeof errorMessage !== 'undefined' ? errorMessage : '';
  const pageSuccess = typeof successMessage !== 'undefined' ? successMessage : '';

  const ownerMember = familyMembers.find((member) => member.role === 'owner');
  const ownerName = ownerMember
    ? ownerMember.name
    : (currentUser ? currentUser.name : 'Current user');
%>

<section class="container page-heading">
  <div>
    <p class="eyebrow">Shared budget workspace</p>
    <h1 class="page-title">Family settings</h1>
    <p class="page-text">
      Manage your shared household, member access and collaboration settings for the family budget.
    </p>
  </div>
</section>

<section class="container family-grid">
  <div class="family-main">
    <div class="section-card family-overview-card">
      <div class="section-header family-section-header">
        <div>
          <p class="section-label">Overview</p>
          <h2>Budget group information</h2>
        </div>

        <% if (currentFamily) { %>
          <span class="status-badge status-badge-active">Active</span>
        <% } else { %>
          <span class="status-badge">Not created</span>
        <% } %>
      </div>

      <div class="family-overview-stats">
        <div class="family-stat-box">
          <span class="family-stat-label">Family name</span>
          <strong class="family-stat-value">
            <%= currentFamily ? currentFamily.name : 'No family yet' %>
          </strong>
        </div>

        <div class="family-stat-box">
          <span class="family-stat-label">Members</span>
          <strong class="family-stat-value"><%= familyMembers.length %></strong>
        </div>

        <div class="family-stat-box">
          <span class="family-stat-label">Owner</span>
          <strong class="family-stat-value"><%= ownerName %></strong>
        </div>
      </div>

      <p class="family-description">
        <% if (currentFamily) { %>
          Your family workspace combines shared transactions, categories, financial planning and activity tracking in one place.
        <% } else { %>
          Create a family workspace to start sharing categories, transactions and planning tools with other registered users.
        <% } %>
      </p>

      <% if (pageError) { %>
        <div class="alert alert-danger"><%= pageError %></div>
      <% } %>

      <% if (pageSuccess) { %>
        <div class="alert alert-success"><%= pageSuccess %></div>
      <% } %>
    </div>

    <% if (!currentFamily) { %>
      <div class="section-card family-create-card">
        <div class="section-header family-section-header">
          <div>
            <p class="section-label">Setup</p>
            <h2>Create your family workspace</h2>
          </div>
        </div>

        <p class="family-description">
          Start by creating one shared family space. After that, you can invite other registered users by email.
        </p>

        <form class="family-form" action="/family/create" method="POST">
          <div class="form-group">
            <label class="form-label" for="familyName">Family name</label>
            <input
              class="form-input"
              id="familyName"
              name="familyName"
              type="text"
              placeholder="Enter family name"
              required
            />
          </div>

          <button class="btn btn-primary" type="submit">Create family</button>
        </form>
      </div>
    <% } %>

    <div class="section-card family-members-card">
      <div class="section-header family-section-header">
        <div>
          <p class="section-label">Members</p>
          <h2>Current family members</h2>
        </div>

        <% if (currentFamily) { %>
          <span class="status-badge status-badge-active">Connected</span>
        <% } else { %>
          <span class="status-badge">Waiting setup</span>
        <% } %>
      </div>

      <div class="family-members-list">
        <% if (!currentFamily) { %>
          <p class="family-empty-text">
            No family members yet because the family workspace has not been created.
          </p>
        <% } else if (familyMembers.length === 0) { %>
          <p class="family-empty-text">
            No members found in this family.
          </p>
        <% } else { %>
          <% familyMembers.forEach((member) => { %>
            <article class="family-member-item">
              <div class="family-member-info">
                <div class="family-member-avatar <%= member.role === 'owner' ? '' : 'family-member-avatar-soft' %>">
                  <%= member.name ? member.name.charAt(0).toUpperCase() : '?' %>
                </div>
                <div>
                  <h3><%= member.name %></h3>
                  <p><%= member.email %></p>
                </div>
              </div>

              <div class="family-member-meta">
                <span class="role-badge <%= member.role === 'owner' ? 'role-badge-owner' : '' %>">
                  <%= member.role === 'owner' ? 'Owner' : 'Member' %>
                </span>

                <div class="family-member-actions">
                  <% if (member.role === 'owner') { %>
                    <button class="btn btn-secondary btn-small" type="button" disabled>
                      Owner account
                    </button>
                  <% } else { %>
                    <button class="btn btn-secondary btn-small" type="button" disabled>
                      Member linked
                    </button>
                  <% } %>
                </div>
              </div>
            </article>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="section-card family-activity-card">
      <div class="section-header family-section-header">
        <div>
          <p class="section-label">Recent activity</p>
          <h2>Latest household updates</h2>
        </div>
      </div>

      <div class="family-activity-list">
        <% if (!currentFamily) { %>
          <article class="family-activity-item">
            <div class="family-activity-dot"></div>
            <div>
              <h3>Family workspace not created yet</h3>
              <p>Create your first family to start shared budget collaboration.</p>
            </div>
            <span class="family-activity-time">Now</span>
          </article>
        <% } else { %>
          <article class="family-activity-item">
            <div class="family-activity-dot"></div>
            <div>
              <h3>Family workspace is active</h3>
              <p>
                The shared family budget <strong><%= currentFamily.name %></strong> is connected to your account.
              </p>
            </div>
            <span class="family-activity-time">Current</span>
          </article>

          <article class="family-activity-item">
            <div class="family-activity-dot"></div>
            <div>
              <h3>Member count updated</h3>
              <p>
                This workspace currently has <strong><%= familyMembers.length %></strong> linked
                <%= familyMembers.length === 1 ? 'member' : 'members' %>.
              </p>
            </div>
            <span class="family-activity-time">Live</span>
          </article>

          <article class="family-activity-item">
            <div class="family-activity-dot"></div>
            <div>
              <h3>Shared features ready</h3>
              <p>Family categories can now be used as a base for transactions and dashboard statistics.</p>
            </div>
            <span class="family-activity-time">Ready</span>
          </article>
        <% } %>
      </div>
    </div>
  </div>

  <aside class="family-sidebar">
    <div class="section-card family-invite-card">
      <div class="section-header family-section-header">
        <div>
          <p class="section-label">Invitation</p>
          <h2>Invite a new member</h2>
        </div>
      </div>

      <form class="family-form" action="/family/add-member" method="POST">
        <div class="form-group">
          <label class="form-label" for="email">Email address</label>
          <input
            class="form-input"
            id="email"
            name="email"
            type="email"
            placeholder="Enter registered user email"
            <%= !currentFamily ? 'disabled' : '' %>
            required
          />
        </div>

        <button class="btn btn-primary" type="submit" <%= !currentFamily ? 'disabled' : '' %>>
          Add member
        </button>
      </form>

      <% if (!currentFamily) { %>
        <p class="family-sidebar-note">
          Create a family first, then you can add other registered users by email.
        </p>
      <% } else if (currentFamily.owner_user_id !== (currentUser ? currentUser.id : null)) { %>
        <p class="family-sidebar-note">
          Only the family owner can add new members.
        </p>
      <% } else { %>
        <p class="family-sidebar-note">
          The invited person must already have an account in My-Budget.
        </p>
      <% } %>
    </div>

    <div class="section-card family-permissions-card">
      <div class="section-header family-section-header">
        <div>
          <p class="section-label">Permissions</p>
          <h2>Access summary</h2>
        </div>
      </div>

      <ul class="family-permissions-list">
        <li>Owners can manage members and shared settings.</li>
        <li>Family members can work with the common budget space.</li>
        <li>Shared categories can be used later in transactions and reports.</li>
        <li>Advanced role editing can be added in the next backend step.</li>
      </ul>

      <div class="family-sidebar-actions">
        <button class="btn btn-secondary" type="button" disabled>Role editor coming later</button>
      </div>
    </div>

    <div class="section-card family-rules-card">
      <div class="section-header family-section-header">
        <div>
          <p class="section-label">Rules</p>
          <h2>Shared budget notes</h2>
        </div>
      </div>

      <div class="family-rules-list">
        <div class="family-rule-item">
          <strong>Transparency</strong>
          <p>All shared transactions should remain visible to every family member.</p>
        </div>

        <div class="family-rule-item">
          <strong>Consistency</strong>
          <p>Use the same categories when recording recurring expenses.</p>
        </div>

        <div class="family-rule-item">
          <strong>Planning</strong>
          <p>Review future purchases together before adding them to the wishlist.</p>
        </div>
      </div>
    </div>
  </aside>
</section>

<%- include('../partials/footer') %>