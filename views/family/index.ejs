<% /* Family workspace page that combines profile header, member management and activity history. */ %>
<%- include('../partials/header') %>

<%
  const currentFamily = typeof family !== 'undefined' ? family : null;
  const familyMembers = Array.isArray(members) ? members : [];
  const activityItems = Array.isArray(activity) ? activity : [];
  const pageError = typeof errorMessage !== 'undefined' ? errorMessage : '';
  const pageSuccess = typeof successMessage !== 'undefined' ? successMessage : '';
  const familyPermissions = typeof permissions !== 'undefined' ? permissions : {};
  const activeRole = typeof currentRole !== 'undefined' ? currentRole : null;
  const memberActivity = Array.isArray(selectedMemberActivity) ? selectedMemberActivity : [];
  const activeMember = typeof selectedMember !== 'undefined' ? selectedMember : null;
  const personalStats = typeof personalWorkspaceStats !== 'undefined' ? personalWorkspaceStats : null;
  const personalActivityItems = Array.isArray(personalWorkspaceActivity) ? personalWorkspaceActivity : [];
%>

<section class="container family-shell">
  <section class="family-page">
    <% if (pageError) { %>
      <div class="alert alert-danger rounded-4 family-alert" role="alert"><%= pageError %></div>
    <% } %>

    <% if (pageSuccess) { %>
      <div class="alert alert-success rounded-4 family-alert" role="alert"><%= pageSuccess %></div>
    <% } %>

    <% if (!currentFamily) { %>
      <div class="d-flex flex-column gap-4">
        <%- include('./empty-state', { currentFamily, familyMembers, personalWorkspaceStats: personalStats }) %>
        <%- include('./personal-activity', { personalActivityItems }) %>
      </div>
    <% } else { %>
      <div class="d-flex flex-column gap-4">
        <%- include('./header', { currentFamily, familyMembers, activeRole, familyPermissions }) %>
        <%- include('./members', { currentFamily, familyMembers, familyPermissions, currentUser }) %>
        <%- include('./activity', { activityItems, familyMembers, activeMember, memberActivity }) %>
      </div>
    <% } %>
  </section>
</section>

<script>
  window.familyI18n = {
    showAll: <%- JSON.stringify(t('family.showAll')) %>,
    hideAll: <%- JSON.stringify(t('family.hideAll')) %>,
    latestUpdates: <%- JSON.stringify(t('family.latestUpdates')) %>,
    member: <%- JSON.stringify(t('family.member')) %>
  };
</script>
<script src="/js/family.js"></script>

<%- include('../partials/footer') %>
