<%- include('../partials/header') %>

<%
  const currentFamily = typeof family !== 'undefined' ? family : null;
  const familyMembers = Array.isArray(members) ? members : [];
  const currentUserId = currentUser ? Number(currentUser.id) : null;
  const pageError = typeof errorMessage !== 'undefined' ? errorMessage : '';
  const pageSuccess = typeof successMessage !== 'undefined' ? successMessage : '';
  const familyPermissions = typeof permissions !== 'undefined' ? permissions : {};
%>

<section class="container page-heading family-page-heading">
  <% if (pageError) { %><div class="alert alert-danger rounded-3"><%= pageError %></div><% } %>
  <% if (pageSuccess) { %><div class="alert alert-success rounded-3"><%= pageSuccess %></div><% } %>
</section>

<section class="container family-page-shell">
  <% if (!currentFamily) { %>
    <%- include('./empty-state') %>
  <% } else { %>
    <div class="row g-4 align-items-start">
      <div class="col-lg-8">
        <div class="d-flex flex-column gap-4">
          <%- include('./header', { currentFamily, familyMembers, currentUserId, familyPermissions }) %>
          <%- include('./members', { currentFamily, familyMembers, currentUserId, familyPermissions }) %>
        </div>
      </div>

      <aside class="col-lg-4">
        <%- include('./actions', { currentFamily, familyMembers, currentUserId, familyPermissions }) %>
      </aside>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
