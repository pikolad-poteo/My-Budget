<% /* Family members table with role controls and owner-only management actions. */ %>
<div class="card family-card family-members-card">
  <div class="card-body">
    <div class="family-section-header family-members-header">
      <div>
        <p class="section-label"><%= t('family.members') %></p>
        <h2><%= t('family.currentFamilyMembers') %></h2>
      </div>

      <button
        class="btn btn-secondary rounded-pill px-4"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#familyPermissionsPanel"
        aria-expanded="false"
        aria-controls="familyPermissionsPanel"
      >
        <i class="bi bi-gear me-2"></i><%= t('family.permissions') %>
      </button>
    </div>

    <div class="collapse" id="familyPermissionsPanel">
      <div class="family-permissions-box">
        <div><span class="family-role-badge family-role-owner"><%= t('family.roles.owner') %></span><p><%= t('family.permissionsOwner') %></p></div>
        <div><span class="family-role-badge family-role-editor"><%= t('family.roles.editor') %></span><p><%= t('family.permissionsEditor') %></p></div>
        <div><span class="family-role-badge family-role-viewer"><%= t('family.roles.viewer') %></span><p><%= t('family.permissionsViewer') %></p></div>
      </div>
    </div>

    <div class="family-members-list">
      <% familyMembers.forEach((member) => { %>
        <% const isCurrentMember = currentUser && Number(member.id) === Number(currentUser.id); %>
        <article class="family-member-item family-member-role-row-<%= member.role %>">
          <div class="family-member-info">
            <% if (member.avatar_url) { %>
              <img class="family-member-avatar" src="<%= member.avatar_url %>" alt="<%= member.name || member.email %> <%= t('family.avatar') %>" />
            <% } else { %>
              <div class="family-member-avatar family-member-avatar-soft" aria-hidden="true">
                <i class="bi bi-person"></i>
              </div>
            <% } %>

            <div>
              <h3 class="family-member-name"><%= member.name || t('family.user') %><% if (isCurrentMember) { %> <span>(<%= t('family.you') %>)</span><% } %></h3>
              <p class="family-member-email"><%= member.email %></p>
              <div class="family-status-row">
                <span class="family-role-badge family-role-<%= member.role %>">
                  <%= t(`family.roles.${member.role}`) %>
                </span>
              </div>
            </div>
          </div>

          <div class="family-member-meta family-member-meta-<%= member.role %>">
            <button
              class="btn btn-primary btn-small family-member-activity-link"
              type="button"
              data-member-activity-button
              data-member-id="<%= member.id %>"
              data-member-name="<%= member.name || member.email %>"
            >
              <%= t('family.activity') %>
            </button>

            <% if (familyPermissions.canManageMembers) { %>
              <form action="/family/members/<%= member.id %>/role" method="POST" class="family-role-form family-preserve-scroll-form" aria-label="<%= t('family.changeRoleFor') %> <%= member.name || member.email %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <select class="form-select rounded-pill family-role-select" name="role" onchange="this.form.submit()">
                  <option value="owner" <%= member.role === 'owner' ? 'selected' : '' %>><%= t('family.roles.owner') %></option>
                  <option value="editor" <%= member.role === 'editor' ? 'selected' : '' %>><%= t('family.roles.editor') %></option>
                  <option value="viewer" <%= member.role === 'viewer' ? 'selected' : '' %>><%= t('family.roles.viewer') %></option>
                </select>
              </form>
            <% } %>

            <% if (isCurrentMember) { %>
              <button class="btn btn-secondary btn-small family-remove-member-btn" type="button" data-bs-toggle="modal" data-bs-target="#leaveFamilyModal">
                <i class="bi bi-person-dash me-2"></i><%= t('family.leaveFamily') %>
              </button>
            <% } else if (familyPermissions.canManageMembers) { %>
              <form action="/family/members/<%= member.id %>/remove" method="POST" class="family-remove-member-form family-preserve-scroll-form" onsubmit="return confirm(<%- JSON.stringify(t('family.confirmRemoveMember')) %>);">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-secondary btn-small family-remove-member-btn" type="submit">
                  <i class="bi bi-trash me-2"></i><%= t('family.remove') %>
                </button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <% if (familyPermissions.canDeleteFamily) { %>
      <div class="family-delete-row">
        <button class="btn btn-danger rounded-pill px-4" type="button" data-bs-toggle="modal" data-bs-target="#deleteFamilyModal">
          <%= t('family.deleteFamily') %>
        </button>
      </div>
    <% } %>
  </div>
</div>

<div class="modal fade" id="leaveFamilyModal" tabindex="-1" aria-labelledby="leaveFamilyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content family-modal-content">
      <div class="modal-header border-0 pb-0">
        <div>
          <p class="section-label mb-1"><%= t('family.workspaceChange') %></p>
          <h2 class="modal-title family-modal-title" id="leaveFamilyModalLabel"><%= t('family.leaveFamilyWorkspace') %></h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('family.close') %>"></button>
      </div>

      <form action="/family/leave" method="POST" class="family-preserve-scroll-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body pt-3">
          <div class="family-warning-box mb-3">
            <i class="bi bi-box-arrow-right"></i>
            <div>
              <strong><%= t('family.leaveWarningTitle') %></strong>
              <p><%= t('family.leaveWarningText') %></p>
            </div>
          </div>
          <label class="family-checkbox-confirm">
            <input type="checkbox" required>
            <span><%= t('family.leaveConfirmText') %></span>
          </label>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal"><%= t('family.cancel') %></button>
          <button type="submit" class="btn btn-primary rounded-pill px-4"><%= t('family.leaveFamily') %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="deleteFamilyModal" tabindex="-1" aria-labelledby="deleteFamilyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content family-modal-content family-delete-modal-content">
      <div class="modal-header border-0 pb-0">
        <div>
          <p class="section-label mb-1 text-danger"><%= t('family.dangerZone') %></p>
          <h2 class="modal-title family-modal-title" id="deleteFamilyModalLabel"><%= t('family.deleteFamilyWorkspace') %></h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('family.close') %>"></button>
      </div>

      <form action="/family/delete" method="POST" class="family-preserve-scroll-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body pt-3">
          <div class="family-danger-box mb-3">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
              <strong><%= t('family.deleteWarningTitle') %></strong>
              <p><%= t('family.deleteWarningText') %></p>
            </div>
          </div>

          <label class="family-transfer-option mb-3">
            <input type="checkbox" name="keepSharedDataAsPersonal">
            <span>
              <strong><%= t('family.moveSharedDataBack') %></strong>
              <small><%= t('family.moveSharedDataBackHelp') %></small>
            </span>
          </label>

          <p class="family-modal-note mb-3">
            <%= t('family.typeDeleteToConfirm') %>
          </p>
          <input class="form-control rounded-pill" name="confirmation" type="text" placeholder="<%= t('family.deleteConfirmationWord') %>" required />
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal"><%= t('family.cancel') %></button>
          <button type="submit" class="btn btn-danger rounded-pill px-4"><%= t('family.delete') %></button>
        </div>
      </form>
    </div>
  </div>
</div>
