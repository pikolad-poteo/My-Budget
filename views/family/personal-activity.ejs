<% /* Personal activity partial used outside a family workspace. */ %>
<%
  const visibleActivity = Array.isArray(personalActivityItems) ? personalActivityItems : [];
  const familyLocale = t('family.locale');

  const getPersonalActivityTitle = (item) => {
    if (!item || !item.action) return t('family.personalUpdate');
    return t(`family.personalActivityTitles.${item.action}`);
  };

  const getPersonalActivityDescription = (item) => {
    if (!item) return '';
    if (item.action === 'category_created') return t('family.personalActivityDescriptions.categoryCreated');
    if (item.action === 'wishlist_folder_created') return t('family.personalActivityDescriptions.wishlistFolderCreated');
    if (item.action === 'wishlist_item_created') return t('family.personalActivityDescriptions.wishlistItemCreated');
    if (item.action === 'calendar_event_created') return t('family.personalActivityDescriptions.calendarEventCreated');
    if (item.action === 'transaction_created') return item.description || t('family.personalActivityDescriptions.transactionCreated');
    return item.description || item.action;
  };
%>

<div class="card family-card family-activity-card family-personal-activity-card" id="memberActivityPanel">
  <div class="card-body">
    <div class="family-section-header family-activity-header">
      <div>
        <p class="section-label"><%= t('family.personalHistory') %></p>
        <h2 id="familyActivityTitle"><%= t('family.latestPersonalUpdates') %></h2>
      </div>

      <div class="family-activity-actions">
        <% if (visibleActivity.length > 0) { %>
          <div class="family-sort-actions d-none" id="familySortActions" aria-label="<%= t('family.sortPersonalActivity') %>">
            <button class="btn btn-primary btn-small family-sort-button is-active" type="button" data-activity-sort-button="desc">
              <%= t('family.new') %>
            </button>
            <button class="btn btn-secondary btn-small family-sort-button" type="button" data-activity-sort-button="asc">
              <%= t('family.old') %>
            </button>
          </div>
        <% } %>
        <button class="btn btn-secondary btn-small family-show-all-button" type="button" id="toggleFamilyActivityButton" aria-expanded="false">
          <%= t('family.showAll') %>
        </button>
      </div>
    </div>

    <div class="family-activity-list" id="familyActivityList" data-expanded="false" data-collapsed="true" data-view-mode="hidden" data-sort="desc">
      <% if (visibleActivity.length === 0) { %>
        <article class="family-activity-item">
          <div class="family-activity-dot"></div>
          <div>
            <h3 class="family-activity-title"><%= t('family.noPersonalActivityYet') %></h3>
            <p class="family-activity-description"><%= t('family.noPersonalActivityDescription') %></p>
          </div>
          <span class="family-activity-time"><%= t('family.empty') %></span>
        </article>
      <% } else { %>
        <% visibleActivity.forEach((item) => { %>
          <article
            class="family-activity-item"
            data-actor-id="personal"
            data-target-id=""
            data-date="<%= item.created_at ? new Date(item.created_at).getTime() : 0 %>"
          >
            <div class="family-activity-dot"></div>
            <div>
              <h3 class="family-activity-title"><%= getPersonalActivityTitle(item) %></h3>
              <p class="family-activity-description"><%= getPersonalActivityDescription(item) %></p>
              <span class="family-activity-type"><%= t(`family.entityTypes.${item.entity_type}`) %> · <%= t(`family.actions.${item.action}`) %></span>
            </div>
            <span class="family-activity-time">
              <%= item.created_at ? new Date(item.created_at).toLocaleDateString(familyLocale) : '' %>
            </span>
          </article>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>
