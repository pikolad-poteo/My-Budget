<%- include('partials/header') %>

<section class="container auth-section">
  <div class="auth-card">
    <p class="eyebrow">Account recovery</p>
    <h1 class="page-title">Forgot password</h1>
    <p class="page-text">Enter your verified email and we will send a password reset link.</p>

    <% if (errorMessage) { %>
      <div class="auth-message auth-message-error"><%= errorMessage %></div>
    <% } %>

    <% if (successMessage) { %>
      <div class="auth-message auth-message-success"><%= successMessage %></div>
    <% } %>

    <form class="auth-form" action="/forgot-password" method="post">
      <div class="form-group">
        <label class="form-label" for="email">Email</label>
        <input
          class="form-input"
          type="email"
          id="email"
          name="email"
          value="<%= email %>"
          placeholder="Enter your email"
        />
      </div>

      <button class="btn btn-primary" type="submit">Send reset link</button>
    </form>

    <div class="auth-footer">
      <p class="auth-footer-text">
        Remembered your password?
        <a href="/login" class="auth-link">Back to login</a>
      </p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
