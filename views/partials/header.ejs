<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= title ? `${title} | My Budget` : 'My Budget' %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  />

  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />

  <link rel="stylesheet" href="/css/pages/dashboard.css" />
  <link rel="stylesheet" href="/css/pages/family.css" />
  <link rel="stylesheet" href="/css/pages/categories.css" />
  <link rel="stylesheet" href="/css/pages/transactions.css" />
  <link rel="stylesheet" href="/css/pages/wishlist.css" />
  <link rel="stylesheet" href="/css/pages/calendar.css" />
  <link rel="stylesheet" href="/css/pages/account.css" />
</head>

<body>
  <header class="site-header sticky-top">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand app-logo" href="<%= currentUser ? '/dashboard' : '/login' %>">
          My Budget
        </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#mainNavbar"
          aria-controls="mainNavbar"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <% if (currentUser) { %>
            <ul class="navbar-nav mx-lg-auto mt-3 mt-lg-0 gap-lg-1">
              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'dashboard' ? 'active' : '' %>" href="/dashboard">
                  Dashboard
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'categories' ? 'active' : '' %>" href="/categories">
                  Categories
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'transactions' ? 'active' : '' %>" href="/transactions">
                  Transactions
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'wishlist' ? 'active' : '' %>" href="/wishlist">
                  Wishlist
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'calendar' ? 'active' : '' %>" href="/calendar">
                  Calendar
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'family' ? 'active' : '' %>" href="/family">
                  Family
                </a>
              </li>
            </ul>
          <% } %>

          <div class="d-flex align-items-lg-center gap-2 ms-lg-auto mt-3 mt-lg-0 flex-column flex-lg-row">
            <% if (currentUser) { %>
              <div class="dropdown app-user-dropdown">
                <button
                  class="app-user-menu-button dropdown-toggle"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="Open account menu"
                >
                  <% if (currentUser.avatar_url) { %>
                    <img class="app-header-avatar" src="<%= currentUser.avatar_url %>" alt="<%= currentUser.name %> avatar" />
                  <% } else { %>
                    <span class="app-header-avatar app-header-avatar-fallback" aria-hidden="true">
                      <i class="bi bi-person app-header-avatar-icon"></i>
                    </span>
                  <% } %>
                  <span class="app-header-user-name"><%= currentUser.name %></span>
                </button>

                <ul class="dropdown-menu dropdown-menu-end app-user-menu shadow-sm">
                  <li>
                    <div class="app-user-menu-head">
                      <strong><%= currentUser.name %></strong>
                      <span><%= currentUser.email %></span>
                    </div>
                  </li>
                  <li><hr class="dropdown-divider" /></li>
                  <li>
                    <a class="dropdown-item app-user-menu-item <%= activePage === 'account' ? 'active' : '' %>" href="/account">
                      <i class="bi bi-person-gear me-2"></i>Account settings
                    </a>
                  </li>
                  <li><hr class="dropdown-divider" /></li>
                  <li>
                    <a class="dropdown-item app-user-menu-item app-user-menu-logout" href="/logout">
                      <i class="bi bi-box-arrow-right me-2"></i>Logout
                    </a>
                  </li>
                </ul>
              </div>
            <% } else { %>
              <a href="/login" class="btn btn-link text-dark text-decoration-none px-2">
                Login
              </a>

              <a href="/register" class="btn btn-dark btn-sm rounded-pill px-3">
                Register
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main class="page">