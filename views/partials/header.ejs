<% /* Shared application header with navigation, language switcher and authenticated-user actions. */ %>
<!DOCTYPE html>
<html lang="<%= language || 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= title ? `${title} | ${t('app.name')}` : t('app.name') %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  />

  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />

  <link rel="stylesheet" href="/css/pages/dashboard.css" />
  <link rel="stylesheet" href="/css/pages/family.css" />
  <link rel="stylesheet" href="/css/pages/categories.css" />
  <link rel="stylesheet" href="/css/pages/transactions.css" />
  <link rel="stylesheet" href="/css/pages/wishlist.css" />
  <link rel="stylesheet" href="/css/pages/calendar.css" />
  <link rel="stylesheet" href="/css/pages/account.css" />
</head>

<body>
  <header class="site-header sticky-top">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand app-logo" href="<%= currentUser ? '/dashboard' : '/login' %>">
          <%= t('app.name') %>
        </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#mainNavbar"
          aria-controls="mainNavbar"
          aria-expanded="false"
          aria-label="<%= t('accessibility.toggleNavigation') %>"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <% if (currentUser) { %>
            <ul class="navbar-nav mx-lg-auto mt-3 mt-lg-0 gap-lg-1">
              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'dashboard' ? 'active' : '' %>" href="/dashboard">
                  <%= t('nav.dashboard') %>
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'categories' ? 'active' : '' %>" href="/categories">
                  <%= t('nav.categories') %>
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'transactions' ? 'active' : '' %>" href="/transactions">
                  <%= t('nav.transactions') %>
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'wishlist' ? 'active' : '' %>" href="/wishlist">
                  <%= t('nav.wishlist') %>
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'calendar' ? 'active' : '' %>" href="/calendar">
                  <%= t('nav.calendar') %>
                </a>
              </li>

              <li class="nav-item">
                <a class="nav-link app-nav-link <%= activePage === 'family' ? 'active' : '' %>" href="/family">
                  <%= t('nav.family') %>
                </a>
              </li>
            </ul>
          <% } %>

          <div class="d-flex align-items-lg-center gap-2 ms-lg-auto mt-3 mt-lg-0 flex-column flex-lg-row">
            <% if (currentUser) { %>
              <div class="dropdown app-user-dropdown">
                <button
                  class="app-user-menu-button dropdown-toggle"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="<%= t('accessibility.openAccountMenu') %>"
                >
                  <% if (currentUser.avatar_url) { %>
                    <img class="app-header-avatar" src="<%= currentUser.avatar_url %>" alt="<%= t('accessibility.userAvatar') %>" />
                  <% } else { %>
                    <span class="app-header-avatar app-header-avatar-fallback" aria-hidden="true">
                      <i class="bi bi-person app-header-avatar-icon"></i>
                    </span>
                  <% } %>
                  <span class="app-header-user-name"><%= currentUser.name %></span>
                </button>

                <ul class="dropdown-menu dropdown-menu-end app-user-menu shadow-sm">
                  <li>
                    <div class="app-user-menu-head">
                      <strong><%= currentUser.name %></strong>
                      <span><%= currentUser.email %></span>
                    </div>
                  </li>
                  <li><hr class="dropdown-divider" /></li>
                  <li>
                    <a class="dropdown-item app-user-menu-item <%= activePage === 'account' ? 'active' : '' %>" href="/account">
                      <i class="bi bi-person-gear me-2"></i><%= t('nav.account') %>
                    </a>
                  </li>
                  <li><hr class="dropdown-divider" /></li>
                  <li>
                    <div class="app-user-menu-language">
                      <div class="app-user-menu-language-title">
                        <i class="bi bi-translate me-2"></i><%= t('language.label') %>
                      </div>

                      <div class="app-user-menu-language-options" aria-label="<%= t('language.label') %>">
                        <a
                          class="app-language-option <%= language === 'en' ? 'active' : '' %>"
                          href="/language/en"
                        >
                          <%= t('language.short.en') %>
                        </a>

                        <a
                          class="app-language-option <%= language === 'ru' ? 'active' : '' %>"
                          href="/language/ru"
                        >
                          <%= t('language.short.ru') %>
                        </a>

                        <a
                          class="app-language-option <%= language === 'et' ? 'active' : '' %>"
                          href="/language/et"
                        >
                          <%= t('language.short.et') %>
                        </a>
                      </div>
                    </div>
                  </li>
                  <li><hr class="dropdown-divider" /></li>
                  <li>
                    <a class="dropdown-item app-user-menu-item app-user-menu-logout" href="/logout">
                      <i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %>
                    </a>
                  </li>
                </ul>
              </div>
            <% } else { %>
              <div class="dropdown app-guest-language-dropdown">
                <button
                  class="app-guest-language-button dropdown-toggle"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="<%= t('language.label') %>"
                >
                  <i class="bi bi-translate" aria-hidden="true"></i>
                  <span><%= t(`language.short.${language}`) %></span>
                </button>

                <ul class="dropdown-menu dropdown-menu-end app-guest-language-menu shadow-sm">
                  <li>
                    <a class="dropdown-item app-user-menu-item <%= language === 'en' ? 'active' : '' %>" href="/language/en">
                      <%= t('language.english') %>
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item app-user-menu-item <%= language === 'ru' ? 'active' : '' %>" href="/language/ru">
                      <%= t('language.russian') %>
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item app-user-menu-item <%= language === 'et' ? 'active' : '' %>" href="/language/et">
                      <%= t('language.estonian') %>
                    </a>
                  </li>
                </ul>
              </div>

              <a href="/login" class="btn btn-link text-dark text-decoration-none px-2">
                <%= t('nav.login') %>
              </a>

              <a href="/register" class="btn btn-dark btn-sm rounded-pill px-3">
                <%= t('nav.register') %>
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main class="page">