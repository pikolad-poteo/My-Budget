<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title ? `${title} | My Budget` : 'My Budget' %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/dashboard" class="logo">My Budget</a>

      <nav class="nav">
        <a href="/dashboard" class="nav-link <%= activePage === 'dashboard' ? 'is-active' : '' %>">Dashboard</a>
        <a href="/categories" class="nav-link <%= activePage === 'categories' ? 'is-active' : '' %>">Categories</a>
        <a href="/transactions" class="nav-link <%= activePage === 'transactions' ? 'is-active' : '' %>">Transactions</a>
        <a href="/family" class="nav-link <%= activePage === 'family' ? 'is-active' : '' %>">Family</a>
        <a href="/wishlist" class="nav-link <%= activePage === 'wishlist' ? 'is-active' : '' %>">Wishlist</a>
        <a href="/calendar" class="nav-link <%= activePage === 'calendar' ? 'is-active' : '' %>">Calendar</a>
      </nav>

      <div class="header-actions">
        <a href="/login" class="header-link">Login</a>
        <a href="/register" class="btn btn-primary btn-small">Register</a>
      </div>
    </div>
  </header>

  <main class="page">