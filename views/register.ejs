<%- include('partials/header') %>

<section class="container auth-section">
  <div class="auth-card">
    <p class="eyebrow">New account</p>
    <h1 class="page-title">Register</h1>
    <p class="page-text">Create an account to start managing your budget.</p>

    <form class="auth-form" action="#" method="post">
      <label class="form-label" for="name">Name</label>
      <input class="form-input" type="text" id="name" name="name" placeholder="Enter your name" />

      <label class="form-label" for="email">Email</label>
      <input class="form-input" type="email" id="email" name="email" placeholder="Enter your email" />

      <label class="form-label" for="password">Password</label>
      <input class="form-input" type="password" id="password" name="password" placeholder="Create a password" />

      <button class="btn btn-primary" type="submit">Create account</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>