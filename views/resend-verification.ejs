<% /* Email verification resend page for users who need a new verification link. */ %>
<%- include('partials/header') %>

<section class="container auth-section">
  <div class="auth-card">
    <p class="eyebrow"><%= t('auth.emailVerification') %></p>
    <h1 class="page-title"><%= t('auth.resendVerificationTitle') %></h1>
    <p class="page-text"><%= t('auth.resendVerificationText') %></p>

    <% if (errorMessage) { %>
      <div class="auth-message auth-message-error"><%= errorMessage %></div>
    <% } %>

    <% if (successMessage) { %>
      <div class="auth-message auth-message-success"><%= successMessage %></div>
    <% } %>

    <form class="auth-form" action="/resend-verification" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label" for="email"><%= t('auth.email') %></label>
        <input
          class="form-input"
          type="email"
          id="email"
          name="email"
          value="<%= email %>"
          placeholder="<%= t('auth.emailPlaceholder') %>"
        />
      </div>

      <button class="btn btn-primary" type="submit"><%= t('auth.sendVerificationEmail') %></button>
    </form>

    <div class="auth-footer">
      <p class="auth-footer-text">
        <a href="/login" class="auth-link"><%= t('auth.backToLogin') %></a>
      </p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
