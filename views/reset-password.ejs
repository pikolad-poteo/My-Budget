<% /* Password reset form rendered after a valid reset token is opened. */ %>
<%- include('partials/header') %>

<section class="container auth-section">
  <div class="auth-card">
    <p class="eyebrow"><%= t('auth.accountRecovery') %></p>
    <h1 class="page-title"><%= t('auth.resetPasswordTitle') %></h1>
    <p class="page-text"><%= t('auth.resetPasswordText') %></p>

    <% if (errorMessage) { %>
      <div class="auth-message auth-message-error"><%= errorMessage %></div>
    <% } %>

    <% if (successMessage) { %>
      <div class="auth-message auth-message-success"><%= successMessage %></div>
    <% } %>

    <% if (isTokenValid) { %>
      <form class="auth-form" action="/reset-password/<%= token %>" method="post">
        <div class="form-group">
          <label class="form-label" for="password"><%= t('auth.newPassword') %></label>
          <input
            class="form-input"
            type="password"
            id="password"
            name="password"
            placeholder="<%= t('auth.newPasswordPlaceholder') %>"
          />
          <p class="form-hint"><%= t('auth.passwordHint') %></p>
        </div>

        <div class="form-group">
          <label class="form-label" for="confirmPassword"><%= t('auth.confirmPassword') %></label>
          <input
            class="form-input"
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            placeholder="<%= t('auth.repeatNewPasswordPlaceholder') %>"
          />
        </div>

        <button class="btn btn-primary" type="submit"><%= t('auth.changePassword') %></button>
      </form>
    <% } %>

    <div class="auth-footer">
      <p class="auth-footer-text">
        <a href="/forgot-password" class="auth-link"><%= t('auth.requestNewResetLink') %></a>
      </p>
      <p class="auth-footer-text">
        <a href="/login" class="auth-link"><%= t('auth.backToLogin') %></a>
      </p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
