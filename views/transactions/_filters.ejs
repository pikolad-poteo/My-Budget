<%
  const currentView = filters.view || 'date';
  const currentDir = filters.dir || 'desc';

  function buildHistoryViewUrl(nextView) {
    const params = new URLSearchParams();
    const nextDir = currentView === nextView && currentDir === 'desc' ? 'asc' : 'desc';

    params.set('view', nextView);
    params.set('dir', nextDir);

    if (filters.from) params.set('from', filters.from);
    if (filters.to) params.set('to', filters.to);
    if (filters.category && filters.category !== 'all') params.set('category', filters.category);
    if (filters.scope && filters.scope !== 'all') params.set('scope', filters.scope);
    if (filters.member && filters.member !== 'all') params.set('member', filters.member);

    if (nextView === 'expenses') {
      params.set('type', 'expense');
    } else if (nextView === 'income') {
      params.set('type', 'income');
    } else if (currentView === 'date' && filters.type && filters.type !== 'all') {
      params.set('type', filters.type);
    }

    return `/transactions?${params.toString()}`;
  }
%>

<section class="section-card transaction-filters-card">
  <div class="section-header transaction-card-header transaction-card-header--history">
    <div>
      <p class="section-label">History</p>
      <h2>Transaction history</h2>
    </div>

    <div class="transaction-history-tools">
      <div class="transaction-view-switch">
        <a
          href="<%= buildHistoryViewUrl('date') %>"
          class="transaction-view-pill <%= (filters.view || 'date') === 'date' ? 'is-active' : '' %>"
          data-history-link
        >
          By date
        </a>

        <a
          href="<%= buildHistoryViewUrl('expenses') %>"
          class="transaction-view-pill <%= filters.view === 'expenses' ? 'is-active' : '' %>"
          data-history-link
        >
          Expenses
        </a>

        <a
          href="<%= buildHistoryViewUrl('income') %>"
          class="transaction-view-pill <%= filters.view === 'income' ? 'is-active' : '' %>"
          data-history-link
        >
          Income
        </a>
      </div>

      <button
        class="transaction-advanced-toggle"
        type="button"
        data-advanced-filters-toggle
        aria-expanded="<%= filters.hasAdvancedFilters ? 'true' : 'false' %>"
      >
        Advanced filters
      </button>
    </div>
  </div>

  <div class="transaction-advanced-panel <%= filters.hasAdvancedFilters ? 'is-open' : '' %>" data-advanced-filters-panel>
    <form class="transaction-filters-form" method="GET" action="/transactions" data-history-form>
      <input type="hidden" name="view" value="<%= filters.view || 'date' %>" />
      <input type="hidden" name="dir" value="<%= filters.dir || 'desc' %>" />

      <div class="transaction-filters-main-grid">
        <div class="form-group">
          <label class="form-label" for="filterFrom">From</label>
          <input class="form-input transaction-date-input" id="filterFrom" name="from" type="date" value="<%= filters.from %>" />
        </div>

        <div class="form-group">
          <label class="form-label" for="filterTo">To</label>
          <input class="form-input transaction-date-input" id="filterTo" name="to" type="date" value="<%= filters.to %>" />
        </div>
      </div>

      <div class="transaction-filters-grid transaction-filters-grid--three">
        <div class="form-group">
          <label class="form-label" for="filterCategory">Category</label>
          <select class="form-input form-select" id="filterCategory" name="category">
            <option value="all" <%= filters.category === 'all' ? 'selected' : '' %>>All categories</option>
            <% categories.forEach((category) => { %>
              <option value="<%= category.id %>" <%= String(filters.category) === String(category.id) ? 'selected' : '' %>>
                <%= category.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="filterType">Type</label>
          <select class="form-input form-select" id="filterType" name="type">
            <option value="all" <%= filters.type === 'all' ? 'selected' : '' %>>All</option>
            <option value="expense" <%= filters.type === 'expense' ? 'selected' : '' %>>Expense</option>
            <option value="income" <%= filters.type === 'income' ? 'selected' : '' %>>Income</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="filterScope">Scope</label>
          <select class="form-input form-select" id="filterScope" name="scope">
            <option value="all" <%= filters.scope === 'all' ? 'selected' : '' %>>All</option>
            <option value="personal" <%= filters.scope === 'personal' ? 'selected' : '' %>>Personal</option>
            <option value="family" <%= filters.scope === 'family' ? 'selected' : '' %>>Family</option>
          </select>
        </div>

        <div class="form-group transaction-filter-member">
          <label class="form-label" for="filterMember">Paid by</label>
          <select class="form-input form-select" id="filterMember" name="member">
            <option value="all" <%= filters.member === 'all' ? 'selected' : '' %>>All members</option>
            <% members.forEach((member) => { %>
              <option value="<%= member.id %>" <%= String(filters.member) === String(member.id) ? 'selected' : '' %>>
                <%= member.name %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="transaction-filter-actions">
        <button class="btn btn-primary" type="submit">Apply filters</button>

        <a href="/transactions?view=date&dir=desc" class="transaction-reset-button" data-history-link>
          Reset
        </a>
      </div>
    </form>
  </div>
</section>