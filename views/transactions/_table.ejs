<%
  function toPositiveAmount(value) {
    return Math.abs(Number(value || 0)).toFixed(2);
  }

  function formatPrettyDate(value) {
    if (!value) return '—';

    const date = new Date(`${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return value;

    return new Intl.DateTimeFormat('en-US', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    }).format(date);
  }
%>

<section class="card border-0 shadow-sm rounded-4 section-card transaction-table-card">
  <div class="card-body p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
      <div>
        <p class="section-label">Transaction</p>
        <h2 class="mb-0">History</h2>
      </div>

      <span class="badge rounded-pill text-bg-light transaction-history-count"><%= transactions.length %> entries</span>
    </div>

    <% if (!transactions.length) { %>
      <div class="alert alert-light border rounded-4 mb-0" role="alert">
        No transactions match the selected filters yet.
      </div>
    <% } else { %>
      <div class="table-responsive transaction-table-responsive">
        <table class="table align-middle transactions-table mb-0">
          <thead>
            <tr>
              <th scope="col">Date</th>
              <th scope="col">Category</th>
              <th scope="col">Paid by</th>
              <th scope="col">Scope</th>
              <th scope="col" class="text-end">Amount</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% transactions.forEach((transaction) => { %>
              <tr>
                <td><span class="transaction-date-text"><%= formatPrettyDate(transaction.transaction_date) %></span></td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <span class="transaction-table-icon" style="background-color: <%= transaction.category_color %>22; color: <%= transaction.category_color %>;">
                      <i class="bi bi-<%= transaction.category_icon %>"></i>
                    </span>
                    <div class="min-w-0">
                      <strong class="d-block"><%= transaction.category_name %></strong>
                      <% if (transaction.description) { %>
                        <div class="transaction-row-note"><%= transaction.description %></div>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td><%= transaction.paid_by_name || '—' %></td>
                <td>
                  <span class="category-meta-pill category-meta-pill--soft"><%= transaction.family_id ? 'Family' : 'Personal' %></span>
                </td>
                <td class="text-end">
                  <span class="transaction-amount <%= transaction.type === 'income' ? 'is-income' : 'is-expense' %>">
                    <%= transaction.type === 'income' ? '+' : '-' %><%= toPositiveAmount(transaction.amount) %> €
                  </span>
                </td>
                <td class="text-end">
                  <div class="dropdown transaction-row-actions">
                    <button
                      class="btn btn-outline-secondary btn-sm rounded-pill px-3 dropdown-toggle"
                      type="button"
                      data-bs-toggle="dropdown"
                      data-bs-auto-close="outside"
                      data-bs-boundary="viewport"
                      aria-expanded="false"
                    >
                      Manage
                    </button>

                    <div class="dropdown-menu dropdown-menu-end transaction-row-actions-dropdown p-3">
                      <form
                        class="transaction-row-edit-form"
                        method="POST"
                        action="/transactions/<%= transaction.id %>/update"
                      >
                        <input type="hidden" name="redirectFrom" value="<%= filters.from %>" />
                        <input type="hidden" name="redirectTo" value="<%= filters.to %>" />
                        <input type="hidden" name="redirectCategory" value="<%= filters.category %>" />
                        <input type="hidden" name="redirectType" value="<%= filters.type %>" />
                        <input type="hidden" name="redirectScope" value="<%= filters.scope %>" />
                        <input type="hidden" name="redirectMember" value="<%= filters.member %>" />
                        <input type="hidden" name="redirectView" value="<%= filters.view || 'date' %>" />
                        <input type="hidden" name="redirectDir" value="<%= filters.dir || 'desc' %>" />
                        <input type="hidden" name="redirectShowAll" value="<%= filters.showAll ? '1' : '' %>" />

                        <div class="row g-2 mb-3">
                          <div class="col-6">
                            <label class="form-label">Type</label>
                            <select class="form-select form-select-sm" name="type">
                              <option value="expense" <%= transaction.type === 'expense' ? 'selected' : '' %>>Expense</option>
                              <option value="income" <%= transaction.type === 'income' ? 'selected' : '' %>>Income</option>
                            </select>
                          </div>

                          <div class="col-6">
                            <label class="form-label">Amount</label>
                            <input class="form-control form-control-sm" type="number" name="amount" min="0.01" step="0.01" value="<%= toPositiveAmount(transaction.amount) %>" required />
                          </div>

                          <div class="col-6">
                            <label class="form-label">Date</label>
                            <input class="form-control form-control-sm" type="date" name="transaction_date" value="<%= transaction.transaction_date %>" required />
                          </div>

                          <div class="col-6">
                            <label class="form-label">Category</label>
                            <select class="form-select form-select-sm" name="category_id" required>
                              <% categories.forEach((category) => { %>
                                <option value="<%= category.id %>" <%= Number(category.id) === Number(transaction.category_id) ? 'selected' : '' %>><%= category.name %></option>
                              <% }) %>
                            </select>
                          </div>

                          <div class="col-12">
                            <label class="form-label">Paid by</label>
                            <select class="form-select form-select-sm" name="paid_by_user_id">
                              <% members.forEach((member) => { %>
                                <option value="<%= member.id %>" <%= Number(member.id) === Number(transaction.paid_by_user_id) ? 'selected' : '' %>><%= member.name %></option>
                              <% }) %>
                            </select>
                          </div>

                          <div class="col-12">
                            <label class="form-label">Description</label>
                            <input class="form-control form-control-sm" type="text" name="description" value="<%= transaction.description || '' %>" />
                          </div>
                        </div>

                        <button class="btn btn-primary btn-sm rounded-pill px-3" type="submit">Save</button>
                      </form>

                      <form
                        method="POST"
                        action="/transactions/<%= transaction.id %>/delete"
                        onsubmit="return confirm('Delete this transaction?');"
                        data-history-mutation-form
                      >
                        <input type="hidden" name="redirectFrom" value="<%= filters.from %>" />
                        <input type="hidden" name="redirectTo" value="<%= filters.to %>" />
                        <input type="hidden" name="redirectCategory" value="<%= filters.category %>" />
                        <input type="hidden" name="redirectType" value="<%= filters.type %>" />
                        <input type="hidden" name="redirectScope" value="<%= filters.scope %>" />
                        <input type="hidden" name="redirectMember" value="<%= filters.member %>" />
                        <input type="hidden" name="redirectView" value="<%= filters.view || 'date' %>" />
                        <input type="hidden" name="redirectDir" value="<%= filters.dir || 'desc' %>" />
                        <input type="hidden" name="redirectShowAll" value="<%= filters.showAll ? '1' : '' %>" />

                        <button class="btn btn-outline-danger btn-sm rounded-pill w-100" type="submit">Delete</button>
                      </form>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>
