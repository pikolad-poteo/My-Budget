<% /* Transactions page shell with overview, filters, create form and history table. */ %>
<%- include('../partials/header') %>

<section class="container transactions-shell">
  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-3 mb-4" role="alert">
      <%= errorMessage %>
    </div>
  <% } %>

  <% if (successMessage) { %>
    <div class="alert alert-success rounded-3 mb-4" role="alert">
      <%= successMessage %>
    </div>
  <% } %>

  <%- include('../partials/page-overview', {
    eyebrow: t('transactions.management'),
    heading: t('transactions.overviewTitle'),
    description: t('transactions.overviewDescription'),
    buttonId: 'toggleTransactionCreateButton',
    buttonTextId: 'toggleTransactionCreateButtonText',
    controlsId: 'transactionCreatePanel',
    buttonLabel: t('transactions.addTransaction'),
    stats: [
      { value: summary.total, label: t('transactions.total') },
      { value: summary.expenseCount, label: t('transactions.expenses') },
      { value: summary.incomeCount, label: t('transactions.income') },
      { value: family ? t('transactions.on') : t('transactions.off'), label: t('transactions.familyMode') }
    ],
    createContent: include('./_form_new', { categories, members, filters })
  }) %>

  <div class="transactions-history-zone" data-transactions-history-zone>
    <%- include('./_filters', { categories, members, filters }) %>
    <%- include('./_table', { transactions, categories, members, filters }) %>
  </div>
</section>

<script>
  window.transactionI18n = <%- JSON.stringify({
    addTransaction: t('transactions.addTransaction'),
    hideForm: t('transactions.hideForm')
  }).replace(/</g, '\\u003c') %>;
</script>
<script src="/js/transactions.js"></script>

<%- include('../partials/footer') %>
