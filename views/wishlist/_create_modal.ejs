<% /* Wishlist create modal with optional image upload and URL-based fields. */ %>
<div class="wishlist-create-panel-inline border-top pt-4" id="wishlistCreatePanel" hidden>
  <form class="wishlist-form wishlist-create-form" data-wishlist-create-form action="/wishlist/create?<%= keepQuery %>&_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
      <div>
        <p class="section-label"><%= t('wishlist.create') %></p>
        <h2 class="h4 mb-0"><%= t('wishlist.newWishlistItem') %></h2>
      </div>
    </div>

    <div class="wishlist-form-grid wishlist-edit-layout-compact">
      <div class="form-group wishlist-form-preview-field wishlist-edit-preview-slot">
        <label class="form-label"><%= t('wishlist.photoPreview') %></label>

        <button
          class="wishlist-photo-preview-wide wishlist-edit-photo-button"
          id="wishlistCreateImagePreview"
          type="button"
          data-empty-label="<%= t('wishlist.preview') %>"
          data-wishlist-upload-trigger="wishlistLocalImage"
          aria-label="<%= t('wishlist.uploadLocalPhoto') %>"
        >
          <i class="bi bi-image"></i>
          <span><%= t('wishlist.preview') %></span>
        </button>

        <span class="wishlist-edit-preview-hint"><%= t('wishlist.clickToUploadLocalPhoto') %></span>

        <button
          class="btn rounded-pill wishlist-edit-preview-reset"
          type="button"
          data-wishlist-reset-preview="wishlistCreateImagePreview"
          data-wishlist-reset-file="wishlistLocalImage"
          data-wishlist-reset-url="wishlistImageUrl"
        >
          <%= t('wishlist.resetPreview') %>
        </button>

        <input
          class="d-none"
          id="wishlistLocalImage"
          name="local_image"
          type="file"
          accept="image/*"
          data-wishlist-image-file-preview="wishlistCreateImagePreview"
        />
      </div>

      <div class="wishlist-edit-fields-panel">
        <div class="wishlist-edit-main-row">
          <div class="form-group">
            <label class="form-label" for="wishlistTitle"><%= t('wishlist.itemName') %></label>
            <input class="form-control" id="wishlistTitle" name="title" type="text" placeholder="<%= t('wishlist.itemNamePlaceholder') %>" required />
          </div>

          <div class="form-group">
            <label class="form-label" for="wishlistPrice"><%= t('wishlist.targetPrice') %></label>
            <div class="wishlist-price-field">
              <span>€</span>
              <input class="form-control" id="wishlistPrice" name="amount" type="number" step="0.01" min="0.01" placeholder="0.00" required />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="wishlistFolder"><%= t('wishlist.folder') %></label>
            <select class="form-select" id="wishlistFolder" name="folder">
              <option value=""><%= t('wishlist.noFolder') %></option>
              <% folders.forEach((folder) => { %>
                <option value="<%= folder %>"><%= folder %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="wishlistDescription"><%= t('wishlist.description') %></label>
          <textarea class="form-control wishlist-edit-description" id="wishlistDescription" name="description" rows="4" placeholder="<%= t('wishlist.descriptionPlaceholder') %>"></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="wishlistImageUrl"><%= t('wishlist.imageLink') %></label>
          <input
            class="form-control"
            id="wishlistImageUrl"
            name="image_url"
            type="url"
            placeholder="https://images.example/item.jpg"
            data-wishlist-image-url-preview="wishlistCreateImagePreview"
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="wishlistProductUrl"><%= t('wishlist.productLink') %></label>
          <input class="form-control" id="wishlistProductUrl" name="product_url" type="url" placeholder="https://store.example/item" />
        </div>

      </div>

      <details class="wishlist-create-advanced wishlist-edit-advanced-details">
        <summary>
          <span><%= t('wishlist.additionalSettings') %></span>
          <i class="bi bi-chevron-down"></i>
        </summary>

        <div class="wishlist-create-advanced-grid wishlist-edit-advanced-grid-open">
          <div class="form-group">
            <label class="form-label" for="wishlistStatus"><%= t('wishlist.statusLabel') %></label>
            <select class="form-select" id="wishlistStatus" name="status">
              <option value="planned" selected><%= t('wishlist.status.planned') %></option>
              <option value="postponed"><%= t('wishlist.status.postponed') %></option>
              <option value="bought"><%= t('wishlist.status.bought') %></option>
              <option value="cancelled"><%= t('wishlist.status.cancelled') %></option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="wishlistBuyer"><%= t('wishlist.whoWantsToBuyIt') %></label>
            <select class="form-select" id="wishlistBuyer" name="user_id">
              <% const wishlistCreateFamilyMembers = typeof familyMembers !== 'undefined' && Array.isArray(familyMembers) ? familyMembers : []; %>
              <% if (wishlistCreateFamilyMembers.length > 0) { %>
                <% wishlistCreateFamilyMembers.forEach((member) => { %>
                  <option value="<%= member.id %>" <%= currentUser && Number(member.id) === Number(currentUser.id) ? 'selected' : '' %>><%= member.name || member.email || t('wishlist.familyMember') %></option>
                <% }) %>
              <% } else { %>
                <option value="<%= currentUser && currentUser.id ? currentUser.id : '' %>"><%= currentUser && currentUser.name ? currentUser.name : t('wishlist.me') %></option>
              <% } %>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="wishlistDeadline"><%= t('wishlist.desiredBy') %></label>
            <input class="form-control" id="wishlistDeadline" name="desired_date" type="date" />
          </div>
        </div>
      </details>
    </div>

    <div class="wishlist-form-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
      <button class="btn btn-primary rounded-pill px-4" type="submit"><%= t('wishlist.saveItem') %></button>
      <button class="btn btn-outline-secondary rounded-pill px-4" type="reset"><%= t('wishlist.clearForm') %></button>
    </div>
  </form>
</div>
