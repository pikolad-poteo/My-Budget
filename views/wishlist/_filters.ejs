<% /* Wishlist filters and family-member selector partial. */ %>
<section class="card border-0 shadow-sm rounded-4 section-card wishlist-filters-card">
  <div class="card-body p-4">
    <div class="row align-items-center g-3 mb-4">
      <div class="col-lg-7">
        <p class="section-label"><%= t('wishlist.organization') %></p>
        <h2 class="h3 fw-bold mb-1"><%= t('wishlist.foldersAndFilters') %></h2>
        <p class="wishlist-toolbar-text mb-0"><%= t('wishlist.filtersDescription') %></p>
      </div>

      <div class="col-lg-5 d-grid d-sm-flex justify-content-lg-end gap-2">
        <button
          type="button"
          class="btn btn-outline-secondary rounded-pill px-4"
          id="toggleWishlistFoldersButton"
          aria-expanded="<%= shouldShowFolders || !hasFoldersToShow ? 'true' : 'false' %>"
          aria-controls="wishlistFoldersPanel"
        >
          <i class="bi bi-folder2-open me-2"></i>
          <span id="toggleWishlistFoldersText"><%= shouldShowFolders || !hasFoldersToShow ? t('wishlist.hideFolders') : t('wishlist.showFolders') %></span>
        </button>

        <% if (hasActiveFilters) { %>
          <a href="/wishlist" class="btn btn-outline-secondary rounded-pill px-4 wishlist-reset-btn"><%= t('wishlist.clearFilters') %></a>
        <% } %>
      </div>
    </div>

    <%
      const formatMemberTabLabel = (member) => {
        const rawName = member.name || member.email || t('wishlist.familyMember');
        const rawRole = member.role ? String(member.role).charAt(0).toUpperCase() + String(member.role).slice(1) : '';
        return rawRole && !String(rawName).toLowerCase().endsWith(rawRole.toLowerCase()) ? `${rawName} ${rawRole}` : rawName;
      };
    %>

    <%
      const activeMember = familyMembers.find((member) => String(member.id) === String(activeBuyer));
      const activeMemberLabel = activeBuyer === 'all' ? t('wishlist.allFamily') : (activeMember ? formatMemberTabLabel(activeMember) : t('wishlist.allFamily'));
    %>

    <div class="wishlist-folder-toolbar mb-4" aria-label="<%= t('wishlist.folderControls') %>">
      <div class="wishlist-folder-viewer">
        <span><%= t('wishlist.showing') %></span>
        <strong><%= activeMemberLabel %></strong>
      </div>

      <div class="wishlist-folder-toolbar-actions">
        <details class="wishlist-member-dropdown">
          <summary class="wishlist-member-circle" aria-label="<%= t('wishlist.chooseFamilyMemberContent') %>">
            <i class="bi <%= activeBuyer === 'all' ? 'bi-people' : 'bi-person' %>"></i>
          </summary>
          <div class="wishlist-member-menu" role="group" aria-label="<%= t('wishlist.showWishlistContentFor') %>">
            <button class="wishlist-member-menu-item <%= activeBuyer === 'all' ? 'is-active' : '' %>" type="button" data-wishlist-buyer-filter="all">
              <i class="bi bi-people"></i>
              <span><%= t('wishlist.allFamily') %></span>
            </button>
            <% familyMembers.forEach((member) => { %>
              <button class="wishlist-member-menu-item <%= String(activeBuyer) === String(member.id) ? 'is-active' : '' %>" type="button" data-wishlist-buyer-filter="<%= member.id %>">
                <i class="bi bi-person"></i>
                <span><%= formatMemberTabLabel(member) %></span>
              </button>
            <% }) %>
          </div>
        </details>

        <button class="btn btn-primary rounded-pill px-4 wishlist-create-folder-button" type="button" data-folder-create-open>
          <i class="bi bi-plus-lg me-1"></i><%= t('wishlist.createFolder') %>
        </button>
      </div>
    </div>

    <div class="wishlist-folders-panel mb-4" id="wishlistFoldersPanel" <%= shouldShowFolders || !hasFoldersToShow ? '' : 'hidden' %>>

      <%
        const visibleAllItems = activeBuyer === 'all'
          ? allWishlistItems
          : allWishlistItems.filter((item) => String(item.user_id) === String(activeBuyer));
        const getFolderPreviewItems = (folderName, ownerId) => {
          const source = allWishlistItems.filter((item) => (
            (item.folder || '') === folderName
            && (!ownerId || String(item.user_id) === String(ownerId))
          ));
          return source.slice(0, 6);
        };
        const getFolderStatKey = (folderName, ownerId) => `${ownerId || ''}::${String(folderName || '').toLowerCase()}`;
        const folderCardsToShow = Array.isArray(folderCards) ? folderCards : [];
      %>
      <% if (!folderCardsToShow.length) { %>
        <div class="card border-0 rounded-4 bg-light wishlist-folder-empty">
          <div class="card-body p-4 d-flex flex-column flex-md-row align-items-md-center gap-3">
            <span class="wishlist-folder-empty-icon"><i class="bi bi-folder2-open"></i></span>
            <div>
              <h3 class="h5 fw-bold mb-1"><%= t('wishlist.noFoldersYet') %></h3>
              <p class="wishlist-toolbar-text mb-0"><%= t('wishlist.noFoldersDescription') %></p>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="row g-3 wishlist-folder-grid">
          <% folderCardsToShow.forEach((folderCard) => { %>
            <% const folder = folderCard.name; %>
            <% const folderOwnerId = folderCard.user_id; %>
            <% const folderOwnerName = folderCard.owner_name || t('wishlist.familyMember'); %>
            <% const folderInfo = folderStats && folderStats[getFolderStatKey(folder, folderOwnerId)] ? folderStats[getFolderStatKey(folder, folderOwnerId)] : { count: 0, total: 0 }; %>
            <% const previewItems = getFolderPreviewItems(folder, folderOwnerId); %>
            <div class="col-md-6 col-xl-4">
              <article class="card border-0 rounded-4 bg-light h-100 wishlist-folder-card wishlist-folder-card-preview wishlist-folder-card-manageable <%= activeFolder === folder ? 'is-active' : '' %>">
                <a class="wishlist-folder-card-link" data-wishlist-folder-link href="/wishlist?folder=<%= encodeURIComponent(folder) %>&status=<%= encodeURIComponent(activeStatus) %>&sort=<%= encodeURIComponent(activeSort) %>&buyer=<%= encodeURIComponent(folderOwnerId) %>&q=<%= encodeURIComponent(searchQuery) %>">
                  <span class="wishlist-folder-main">
                    <strong title="<%= folder %>"><%= folder %></strong>
                  </span>
                  <div class="wishlist-folder-preview-grid" aria-hidden="true">
                    <% for (let i = 0; i < 6; i += 1) { %>
                      <% const previewItem = previewItems[i]; %>
                      <span class="wishlist-folder-preview-cell">
                        <% if (previewItem && previewItem.image_url) { %>
                          <img src="<%= previewItem.image_url %>" alt="" />
                        <% } else if (previewItem) { %>
                          <i class="bi bi-bag-heart"></i>
                        <% } %>
                      </span>
                    <% } %>
                  </div>
                </a>

                <span class="wishlist-folder-owner" title="<%= folderOwnerName %>">
                  <i class="bi bi-person"></i>
                  <%= folderOwnerName %>
                </span>

                <div class="wishlist-folder-footer">
                  <span class="wishlist-folder-total">
                    <strong><%= formatMoney(folderInfo.total) %></strong>
                    <small><%= t('wishlist.items') %>: <%= folderInfo.count %></small>
                  </span>
                  <div class="wishlist-folder-actions" role="group" aria-label="<%= t('wishlist.folderActions') %>">
                  <button type="button" class="btn btn-light" data-wishlist-add-existing-folder="<%= folder %>" data-wishlist-add-existing-owner-id="<%= folderOwnerId %>" <%= allWishlistItems.length === 0 ? 'disabled' : '' %> aria-label="<%= t('wishlist.addExistingItemsToFolder') %>">
                    <i class="bi bi-plus-lg"></i>
                  </button>
                  <button type="button" class="btn btn-light" data-folder-rename-open="<%= folder %>" data-folder-owner-id="<%= folderOwnerId %>" aria-label="<%= t('wishlist.renameFolder') %>">
                    <i class="bi bi-pencil"></i>
                  </button>
                    <button type="button" class="btn btn-light text-danger" data-folder-delete-open="<%= folder %>" data-folder-owner-id="<%= folderOwnerId %>" data-folder-count="<%= folderInfo.count %>" aria-label="<%= t('wishlist.deleteFolder') %>">
                      <i class="bi bi-trash3"></i>
                    </button>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <form class="wishlist-advanced-filters" id="wishlistAdvancedFilters" action="/wishlist" method="GET">
      <input type="hidden" name="folder" value="<%= activeFolder %>" />
      <input type="hidden" name="buyer" value="<%= activeBuyer %>" />

      <div class="row g-3 align-items-center wishlist-filter-row">
        <div class="col-lg-4 col-xl-4">
          <div class="input-group wishlist-bootstrap-search <%= searchQuery ? 'has-live-query' : '' %>">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
            <input
              type="search"
              class="form-control border-start-0"
              id="wishlistLiveSearchInput"
              name="q"
              value="<%= searchQuery %>"
              placeholder="<%= t('wishlist.searchWishlist') %>"
              autocomplete="off"
              aria-label="<%= t('wishlist.searchWishlist') %>"
              data-wishlist-hot-search
            />
            <button
              class="btn btn-outline-secondary px-4 wishlist-search-clear"
              type="button"
              id="wishlistLiveSearchClear"
              <%= searchQuery ? '' : 'hidden' %>
            >
              Clear
            </button>
          </div>
        </div>

        <div class="col-lg-5 col-xl-5">
          <input type="hidden" name="status" value="<%= activeStatus %>" />
          <div class="btn-group wishlist-filter-status-buttons wishlist-view-switch" role="group" aria-label="<%= t('wishlist.filterByStatus') %>">
            <button class="btn wishlist-view-pill <%= activeStatus === 'all' ? 'is-active' : '' %>" type="button" data-wishlist-status-filter="all"><%= t('wishlist.all') %></button>
            <button class="btn wishlist-view-pill <%= activeStatus === 'planned' ? 'is-active' : '' %>" type="button" data-wishlist-status-filter="planned"><%= t('wishlist.status.planned') %></button>
            <button class="btn wishlist-view-pill <%= activeStatus === 'postponed' ? 'is-active' : '' %>" type="button" data-wishlist-status-filter="postponed"><%= t('wishlist.status.postponed') %></button>
            <button class="btn wishlist-view-pill <%= activeStatus === 'bought' ? 'is-active' : '' %>" type="button" data-wishlist-status-filter="bought"><%= t('wishlist.status.bought') %></button>
          </div>
        </div>

        <div class="col-lg-3 col-xl-3 d-flex gap-2 align-items-stretch justify-content-lg-end">
          <select class="form-select wishlist-sort-select flex-grow-1" name="sort" data-wishlist-auto-filter aria-label="<%= t('wishlist.sortWishlist') %>">
            <option value="newest" <%= activeSort === 'newest' ? 'selected' : '' %>><%= t('wishlist.sort.newest') %></option>
            <option value="oldest" <%= activeSort === 'oldest' ? 'selected' : '' %>><%= t('wishlist.sort.oldest') %></option>
            <option value="price_desc" <%= activeSort === 'price_desc' ? 'selected' : '' %>><%= t('wishlist.sort.priceDesc') %></option>
            <option value="price_asc" <%= activeSort === 'price_asc' ? 'selected' : '' %>><%= t('wishlist.sort.priceAsc') %></option>
          </select>
        </div>
      </div>
    </form>
  </div>
</section>
