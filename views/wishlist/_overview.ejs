  <section class="card border-0 shadow-sm rounded-4 section-card wishlist-overview-panel">
    <div class="card-body p-4">
      <div class="row align-items-start g-4 mb-4">
        <div class="col-lg-8">
          <p class="section-label">Management</p>
          <h2 class="h3 fw-bold mb-2">Wishlist overview</h2>
          <p class="wishlist-toolbar-text">
            Plan future purchases, sort them by folders and check how your planned spending affects the current budget.
          </p>
        </div>

        <div class="col-lg-4 d-grid d-lg-flex justify-content-lg-end">
          <button
            type="button"
            class="btn btn-primary rounded-pill px-4"
            id="toggleWishlistCreateButton"
            aria-expanded="false"
            aria-controls="wishlistCreatePanel"
          >
            <i class="bi bi-plus-lg me-2"></i>
            <span id="toggleWishlistCreateButtonText">Add item</span>
          </button>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
          <article class="card border-0 rounded-4 bg-light h-100 categories-bootstrap-stat wishlist-bootstrap-stat">
            <div class="card-body p-3">
              <span class="categories-stat-value d-block"><%= formatMoney(summary.balance) %></span>
              <span class="categories-stat-label">Current balance</span>
            </div>
          </article>
        </div>

        <div class="col-6 col-lg-3">
          <article class="card border-0 rounded-4 bg-light h-100 categories-bootstrap-stat wishlist-bootstrap-stat">
            <div class="card-body p-3">
              <span class="categories-stat-value d-block"><%= formatMoney(summary.plannedTotal) %></span>
              <span class="categories-stat-label">Planned spending</span>
            </div>
          </article>
        </div>

        <div class="col-6 col-lg-3">
          <article class="card border-0 rounded-4 bg-light h-100 categories-bootstrap-stat wishlist-bootstrap-stat">
            <div class="card-body p-3">
              <span class="categories-stat-value d-block"><%= formatMoney(summary.balanceAfterPlans) %></span>
              <span class="categories-stat-label">Balance after plans</span>
            </div>
          </article>
        </div>

        <div class="col-6 col-lg-3">
          <article class="card border-0 rounded-4 bg-light h-100 categories-bootstrap-stat wishlist-bootstrap-stat">
            <div class="card-body p-3">
              <span class="categories-stat-value d-block"><%= summary.totalItems %></span>
              <span class="categories-stat-label">Wishlist items</span>
            </div>
          </article>
        </div>
      </div>

      <%- include('./_create_modal') %>
    </div>
  </section>