<% /* Shared wishlist modals for editing folders, assigning items and confirming actions. */ %>
<div class="wishlist-modal" id="wishlistFolderCreateModal" hidden>
  <div class="wishlist-modal-backdrop" data-folder-modal-close></div>
  <form class="wishlist-modal-card card border-0 rounded-4" action="/wishlist/folders/create?<%= keepQuery %>" method="POST">
    <div class="wishlist-modal-header">
      <div>
        <p class="section-label"><%= t('wishlist.createFolder') %></p>
        <h3><%= t('wishlist.newFolder') %></h3>
      </div>
      <button type="button" class="wishlist-modal-close" data-folder-modal-close aria-label="<%= t('wishlist.close') %>"><i class="bi bi-x-lg"></i></button>
    </div>

    <input type="hidden" name="status" value="<%= activeStatus %>" />
    <input type="hidden" name="folder" value="<%= activeFolder %>" />
    <input type="hidden" name="sort" value="<%= activeSort %>" />
    <input type="hidden" name="buyer" value="<%= activeBuyer %>" />
    <input type="hidden" name="q" value="<%= searchQuery %>" />

    <div class="row g-3">
      <div class="col-md-7">
        <label class="form-label" for="wishlistCreateFolderName"><%= t('wishlist.folderName') %></label>
        <input class="form-control" name="name" id="wishlistCreateFolderName" maxlength="100" placeholder="<%= t('wishlist.folderName') %>" required />
      </div>

      <div class="col-md-5">
        <label class="form-label" for="wishlistCreateFolderOwner"><%= t('wishlist.familyMember') %></label>
        <select class="form-select" name="user_id" id="wishlistCreateFolderOwner" required>
          <% familyMembers.forEach((member) => { %>
            <%
              const rawName = member.name || member.email || t('wishlist.familyMember');
              const rawRole = member.role ? String(member.role).charAt(0).toUpperCase() + String(member.role).slice(1) : '';
              const memberLabel = rawRole && !String(rawName).toLowerCase().endsWith(rawRole.toLowerCase()) ? `${rawName} ${rawRole}` : rawName;
            %>
            <option value="<%= member.id %>" <%= String(activeBuyer) === String(member.id) || (activeBuyer === 'all' && currentUser && String(currentUser.id) === String(member.id)) ? 'selected' : '' %>>
              <%= memberLabel %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="wishlist-modal-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
      <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-folder-modal-close><%= t('wishlist.cancel') %></button>
      <button type="submit" class="btn btn-primary rounded-pill px-4"><%= t('wishlist.createFolder') %></button>
    </div>
  </form>
</div>

<div class="wishlist-modal" id="wishlistFolderRenameModal" hidden>
  <div class="wishlist-modal-backdrop" data-folder-modal-close></div>
  <form class="wishlist-modal-card card border-0 rounded-4" action="/wishlist/folders/rename?<%= keepQuery %>" method="POST">
    <div class="wishlist-modal-header">
      <div>
        <p class="section-label"><%= t('wishlist.renameFolder') %></p>
        <h3><%= t('wishlist.editFolderName') %></h3>
      </div>
      <button type="button" class="wishlist-modal-close" data-folder-modal-close aria-label="<%= t('wishlist.close') %>"><i class="bi bi-x-lg"></i></button>
    </div>

    <input type="hidden" name="old_name" id="wishlistRenameOldName" />
    <input type="hidden" name="old_user_id" id="wishlistRenameOldUserId" />

    <div class="row g-3">
      <div class="col-md-7">
        <label class="form-label" for="wishlistRenameNewName"><%= t('wishlist.newFolderName') %></label>
        <input class="form-control" name="new_name" id="wishlistRenameNewName" maxlength="100" required />
      </div>

      <div class="col-md-5">
        <label class="form-label" for="wishlistRenameOwner"><%= t('wishlist.folderOwner') %></label>
        <select class="form-select" name="user_id" id="wishlistRenameOwner">
          <% familyMembers.forEach((member) => { %>
            <option value="<%= member.id %>"><%= member.name || member.email || t('wishlist.familyMember') %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="wishlist-modal-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
      <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-folder-modal-close><%= t('wishlist.cancel') %></button>
      <button type="submit" class="btn btn-primary rounded-pill px-4"><%= t('wishlist.saveName') %></button>
    </div>
  </form>
</div>

<div class="wishlist-modal" id="wishlistFolderDeleteModal" hidden>
  <div class="wishlist-modal-backdrop" data-folder-modal-close></div>
  <form class="wishlist-modal-card card border-0 rounded-4" action="/wishlist/folders/delete?<%= keepQuery %>" method="POST">
    <div class="wishlist-modal-header">
      <div>
        <p class="section-label"><%= t('wishlist.deleteFolder') %></p>
        <h3 id="wishlistDeleteModalTitle"><%= t('wishlist.deleteFolderQuestion') %></h3>
      </div>
      <button type="button" class="wishlist-modal-close" data-folder-modal-close aria-label="<%= t('wishlist.close') %>"><i class="bi bi-x-lg"></i></button>
    </div>

    <input type="hidden" name="name" id="wishlistDeleteFolderName" />
    <input type="hidden" name="owner_id" id="wishlistDeleteFolderOwnerId" />

    <p class="wishlist-modal-text" id="wishlistDeleteModalText">
      <%= t('wishlist.deleteFolderText') %>
    </p>

    <label class="wishlist-delete-option">
      <input type="radio" name="delete_action" value="move_to_general" checked />
      <span>
        <strong><%= t('wishlist.deleteOnlyFolder') %></strong>
        <small><%= t('wishlist.deleteOnlyFolderHelp') %></small>
      </span>
    </label>

    <label class="wishlist-delete-option is-danger">
      <input type="radio" name="delete_action" value="delete_items" />
      <span>
        <strong><%= t('wishlist.deleteFolderAndItems') %></strong>
        <small><%= t('wishlist.deleteFolderAndItemsHelp') %></small>
      </span>
    </label>

    <div class="wishlist-modal-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
      <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-folder-modal-close><%= t('wishlist.cancel') %></button>
      <button type="submit" class="btn btn-danger rounded-pill px-4"><%= t('wishlist.deleteFolder') %></button>
    </div>
  </form>
</div>

<div class="wishlist-modal" id="wishlistItemDeleteModal" hidden>
  <div class="wishlist-modal-backdrop" data-wishlist-item-modal-close></div>
  <form class="wishlist-modal-card card border-0 rounded-4 wishlist-delete-item-modal" id="wishlistItemDeleteForm" action="/wishlist" method="POST">
    <div class="wishlist-modal-header">
      <div>
        <p class="section-label"><%= t('wishlist.deleteItem') %></p>
        <h3 id="wishlistItemDeleteTitle"><%= t('wishlist.deleteItemQuestion') %></h3>
      </div>
      <button type="button" class="wishlist-modal-close" data-wishlist-item-modal-close aria-label="<%= t('wishlist.close') %>"><i class="bi bi-x-lg"></i></button>
    </div>

    <p class="wishlist-modal-text"><%= t('wishlist.actionCannotBeUndone') %></p>

    <div class="wishlist-modal-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
      <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-wishlist-item-modal-close><%= t('wishlist.cancel') %></button>
      <button type="submit" class="btn btn-danger rounded-pill px-4"><%= t('wishlist.deleteItem') %></button>
    </div>
  </form>
</div>

<div class="wishlist-modal" id="wishlistAddChoiceModal" hidden>
  <div class="wishlist-modal-backdrop" data-wishlist-add-modal-close></div>
  <div class="wishlist-modal-card card border-0 rounded-4 wishlist-add-choice-modal-card">
    <div class="wishlist-modal-header">
      <div>
        <p class="section-label"><%= t('wishlist.addItem') %></p>
        <h3><%= t('wishlist.whatDoYouWantToAdd') %></h3>
      </div>
      <button type="button" class="wishlist-modal-close" data-wishlist-add-modal-close aria-label="<%= t('wishlist.close') %>"><i class="bi bi-x-lg"></i></button>
    </div>

    <div class="wishlist-add-choice-grid">
      <button type="button" class="wishlist-add-choice-card" data-wishlist-add-new>
        <span><i class="bi bi-plus-lg"></i></span>
        <strong><%= t('wishlist.createNewItem') %></strong>
        <small><%= t('wishlist.createNewItemHelp') %></small>
      </button>

      <button type="button" class="wishlist-add-choice-card" data-wishlist-add-existing <%= folders.length === 0 || allWishlistItems.length === 0 ? 'disabled' : '' %>>
        <span><i class="bi bi-collection"></i></span>
        <strong><%= t('wishlist.addExistingCard') %></strong>
        <small><%= t('wishlist.addExistingCardHelp') %></small>
      </button>
    </div>

    <% if (folders.length === 0) { %>
      <p class="wishlist-modal-hint mt-3 mb-0"><%= t('wishlist.createFolderFirstHint') %></p>
    <% } else if (allWishlistItems.length === 0) { %>
      <p class="wishlist-modal-hint mt-3 mb-0"><%= t('wishlist.noExistingCardsHint') %></p>
    <% } %>
  </div>
</div>

<div class="wishlist-modal wishlist-existing-items-modal" id="wishlistExistingItemsModal" hidden>
  <div class="wishlist-modal-backdrop" data-wishlist-add-modal-close></div>
  <form class="wishlist-modal-card card border-0 rounded-4 wishlist-existing-items-card" action="/wishlist/folders/add-items?<%= keepQuery %>" method="POST">
    <div class="wishlist-modal-header">
      <div>
        <p class="section-label"><%= t('wishlist.existingCards') %></p>
        <h3><%= t('wishlist.addCardsToFolder') %></h3>
      </div>
      <button type="button" class="wishlist-modal-close" data-wishlist-add-modal-close aria-label="<%= t('wishlist.close') %>"><i class="bi bi-x-lg"></i></button>
    </div>

    <input type="hidden" name="status" value="<%= activeStatus %>" />
    <input type="hidden" name="folder" value="<%= activeFolder %>" />
    <input type="hidden" name="sort" value="<%= activeSort %>" />
    <input type="hidden" name="q" value="<%= searchQuery %>" />

    <%
      const existingFolderChoices = Array.isArray(folderCards) && folderCards.length
        ? folderCards
        : folders.map((folder) => ({ name: folder, user_id: currentUser ? currentUser.id : '', owner_name: '' }));
      const existingDefaultChoice = existingFolderChoices.find((folderCard) => (
        currentFolderName
        && folderCard.name === currentFolderName
        && (activeBuyer === 'all' || String(folderCard.user_id) === String(activeBuyer))
      )) || existingFolderChoices[0];
      const existingDefaultKey = existingDefaultChoice ? `${existingDefaultChoice.user_id}::${existingDefaultChoice.name}` : '';
    %>

    <input type="hidden" name="target_folder" id="wishlistExistingTargetFolderName" value="<%= existingDefaultChoice ? existingDefaultChoice.name : '' %>" />
    <input type="hidden" name="target_owner_id" id="wishlistExistingTargetOwnerId" value="<%= existingDefaultChoice ? existingDefaultChoice.user_id : '' %>" />

    <div class="form-group wishlist-existing-target mb-3">
      <label class="form-label" for="wishlistExistingTargetFolder"><%= t('wishlist.targetFolder') %></label>
      <select class="form-select" id="wishlistExistingTargetFolder" required>
        <% if (!existingFolderChoices.length) { %>
          <option value="" disabled selected><%= t('wishlist.chooseFolder') %></option>
        <% } %>
        <% existingFolderChoices.forEach((folderCard) => { %>
          <%
            const folderKey = `${folderCard.user_id}::${folderCard.name}`;
            const folderOwnerLabel = folderCard.owner_name ? ` · ${folderCard.owner_name}` : '';
          %>
          <option
            value="<%= folderKey %>"
            data-folder-name="<%= folderCard.name %>"
            data-owner-id="<%= folderCard.user_id %>"
            <%= existingDefaultKey === folderKey ? 'selected' : '' %>
          >
            <%= folderCard.name %><%= folderOwnerLabel %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="wishlist-existing-items-list">
      <% allWishlistItems.forEach((item) => { %>
        <% const alreadyInDefaultFolder = existingDefaultChoice && item.folder === existingDefaultChoice.name && String(item.user_id) === String(existingDefaultChoice.user_id); %>
        <label
          class="wishlist-existing-item-card <%= alreadyInDefaultFolder ? 'is-already-added' : '' %>"
          data-existing-folder-item
          data-item-folder="<%= item.folder || '' %>"
          data-item-owner-id="<%= item.user_id %>"
        >
          <input type="checkbox" name="item_ids" value="<%= item.id %>" data-existing-folder-checkbox <%= alreadyInDefaultFolder ? 'checked' : '' %> />
          <span class="wishlist-existing-check"><i class="bi bi-check-lg"></i></span>
          <span class="wishlist-existing-media">
            <% if (item.image_url) { %>
              <img src="<%= item.image_url %>" alt="<%= item.title %>" />
            <% } else { %>
              <i class="bi bi-bag-heart"></i>
            <% } %>
          </span>
          <span class="wishlist-existing-content">
            <strong title="<%= item.title %>"><%= item.title %></strong>
            <small><%= item.folder || t('wishlist.noFolder') %> · <%= formatMoney(item.amount) %></small>
          </span>
        </label>
      <% }) %>
    </div>

    <div class="wishlist-modal-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
      <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-wishlist-add-modal-close><%= t('wishlist.cancel') %></button>
      <button type="submit" class="btn btn-primary rounded-pill px-4"><%= t('wishlist.saveFolderItems') %></button>
    </div>
  </form>
</div>

<div class="wishlist-modal wishlist-image-modal" id="wishlistImageModal" hidden>
  <div class="wishlist-modal-backdrop" data-wishlist-image-close></div>
  <div class="wishlist-modal-card card border-0 rounded-4 wishlist-image-modal-card">
    <button type="button" class="wishlist-modal-close wishlist-image-modal-close" data-wishlist-image-close aria-label="<%= t('wishlist.closeImage') %>"><i class="bi bi-x-lg"></i></button>
    <img id="wishlistImageModalImg" src="" alt="<%= t('wishlist.wishlistItemImage') %>" />
    <div class="wishlist-image-modal-footer">
      <strong id="wishlistImageModalTitle"><%= t('wishlist.itemImage') %></strong>
      <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" id="wishlistImageModalEditButton"><%= t('wishlist.editItem') %></button>
    </div>
  </div>
</div>
