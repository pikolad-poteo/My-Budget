<% /* Wishlist item detail page with edit and status-management controls. */ %>
<%- include('../partials/header') %>

<%
  const formatMoney = (value) => `${Number(value || 0).toFixed(2)} €`;
  const pageFolders = (typeof folders !== 'undefined' && Array.isArray(folders)) ? folders : [];
  const pageFamilyMembers = (typeof familyMembers !== 'undefined' && Array.isArray(familyMembers)) ? familyMembers : [];
  const pageErrorMessage = typeof errorMessage !== 'undefined' ? errorMessage : null;
  const pageSuccessMessage = typeof successMessage !== 'undefined' ? successMessage : null;
  const statusLabels = {
    planned: t('wishlist.status.planned'),
    postponed: t('wishlist.status.postponed'),
    bought: t('wishlist.status.bought'),
    cancelled: t('wishlist.status.cancelled')
  };
  const statusIcons = {
    planned: 'bi-calendar-check',
    postponed: 'bi-pause-circle',
    bought: 'bi-check2-circle',
    cancelled: 'bi-x-circle'
  };
  const desiredBy = item.buyer_name || t('wishlist.other');
  const isLocalWishlistImage = (value) => String(value || '').startsWith('/uploads/wishlist/');
  const isExternalWishlistImage = (value) => /^https?:\/\//i.test(String(value || ''));
  const editableImageLink = isExternalWishlistImage(item.image_url) ? item.image_url : '';
%>

<section class="container wishlist-shell wishlist-detail-shell">
  <% if (pageErrorMessage) { %>
    <div class="alert alert-danger border-0 rounded-4 shadow-sm"><%= pageErrorMessage %></div>
  <% } %>
  <% if (pageSuccessMessage) { %>
    <div class="alert alert-success border-0 rounded-4 shadow-sm"><%= pageSuccessMessage %></div>
  <% } %>

  <a class="wishlist-detail-back" href="/wishlist"><i class="bi bi-arrow-left"></i> <%= t('wishlist.backToWishlist') %></a>

  <article class="card border-0 shadow-sm rounded-4 section-card wishlist-detail-card">
    <div class="wishlist-detail-media-column">
      <% if (item.image_url) { %>
        <button
          class="wishlist-detail-preview wishlist-detail-preview-button"
          type="button"
          data-wishlist-image-open="<%= item.image_url %>"
          data-wishlist-image-title="<%= item.title %>"
          data-wishlist-image-edit="<%= item.id %>"
          aria-label="<%= t('wishlist.openImagePreview') %>"
        >
          <img src="<%= item.image_url %>" alt="<%= item.title %>" />
          <span class="wishlist-card-status is-<%= item.status %>">
            <i class="bi <%= statusIcons[item.status] || 'bi-circle' %>"></i>
            <%= statusLabels[item.status] || item.status %>
          </span>
        </button>
      <% } else { %>
        <div class="wishlist-detail-preview">
          <div class="wishlist-detail-placeholder"><i class="bi bi-bag-heart"></i><span><%= t('wishlist.preview') %></span></div>
          <span class="wishlist-card-status is-<%= item.status %>">
            <i class="bi <%= statusIcons[item.status] || 'bi-circle' %>"></i>
            <%= statusLabels[item.status] || item.status %>
          </span>
        </div>
      <% } %>

      <% if (canEditBudget) { %>
        <div class="wishlist-detail-actions-under-image">
          <button class="btn btn-dark rounded-pill px-4" type="button" data-wishlist-edit-open="<%= item.id %>">
            <i class="bi bi-pencil me-2"></i>Edit
          </button>
          <button class="btn btn-outline-danger rounded-pill px-4" type="button" data-wishlist-delete-open data-wishlist-delete-action="/wishlist/<%= item.id %>/delete" data-wishlist-delete-title="<%= item.title %>">
            <i class="bi bi-trash3 me-2"></i>Delete
          </button>
        </div>
      <% } %>
    </div>

    <div class="wishlist-detail-content">
      <div class="wishlist-detail-heading">
        <div>
          <p class="section-label"><%= t('wishlist.wishlistItem') %></p>
          <h1><%= item.title %></h1>
        </div>
      </div>

      <div class="wishlist-detail-price-row">
        <div>
          <span class="wishlist-meta-label"><%= t('wishlist.price') %></span>
          <strong><%= formatMoney(item.amount) %></strong>
        </div>
        <div>
          <span class="wishlist-meta-label"><%= t('wishlist.desiredBy') %></span>
          <strong><%= desiredBy %></strong>
        </div>
      </div>

      <div class="wishlist-detail-info-grid">
        <div class="wishlist-detail-info-card">
          <span><%= t('wishlist.folder') %></span>
          <strong><%= item.folder || t('wishlist.noFolder') %></strong>
        </div>

        <% if (item.product_url) { %>
          <a class="wishlist-detail-info-card wishlist-detail-product-card" href="<%= item.product_url %>" target="_blank" rel="noopener">
            <span><%= t('wishlist.productLink') %></span>
            <strong><i class="bi bi-box-arrow-up-right me-2"></i><%= t('wishlist.openProduct') %></strong>
          </a>
        <% } else { %>
          <div class="wishlist-detail-info-card wishlist-detail-product-card is-disabled">
            <span><%= t('wishlist.productLink') %></span>
            <strong><%= t('wishlist.noLink') %></strong>
          </div>
        <% } %>
      </div>

      <div class="wishlist-detail-description">
        <h2><%= t('wishlist.description') %></h2>
        <p><%= item.description || t('wishlist.noDescriptionAdded') %></p>
      </div>


      <% if (canEditBudget) { %>
        <form class="wishlist-status-actions wishlist-detail-status-actions" action="/wishlist/<%= item.id %>/status" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="return_to" value="/wishlist/<%= item.id %>" />
          <button class="btn btn-outline-secondary wishlist-status-option <%= item.status === 'planned' ? 'is-active is-planned' : '' %>" name="status" value="planned" type="submit"><%= t('wishlist.status.planned') %></button>
          <button class="btn btn-outline-secondary wishlist-status-option <%= item.status === 'postponed' ? 'is-active is-postponed' : '' %>" name="status" value="postponed" type="submit"><%= t('wishlist.status.postponed') %></button>
          <button class="btn btn-outline-secondary wishlist-status-option <%= item.status === 'bought' ? 'is-active is-bought' : '' %>" name="status" value="bought" type="submit"><%= t('wishlist.status.bought') %></button>
        </form>
      <% } %>
    </div>
  </article>

  <% if (canEditBudget) { %>
    <div class="wishlist-modal wishlist-item-edit-modal" id="wishlistEdit<%= item.id %>" hidden>
      <div class="wishlist-modal-backdrop" data-wishlist-item-modal-close></div>
      <form class="wishlist-modal-card wishlist-edit-panel card border-0 rounded-4" action="/wishlist/<%= item.id %>/update?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="wishlist-modal-header">
          <div>
            <p class="section-label"><%= t('wishlist.editWishlistItem') %></p>
            <h3><%= t('wishlist.edit') %> <%= item.title %></h3>
          </div>
          <button type="button" class="wishlist-modal-close" data-wishlist-item-modal-close aria-label="<%= t('wishlist.closeEditForm') %>"><i class="bi bi-x-lg"></i></button>
        </div>

        <input type="hidden" name="return_to" value="/wishlist/<%= item.id %>" />
        <input type="hidden" name="reset_local_image" id="resetLocalImage<%= item.id %>" value="0" />

        <div class="wishlist-edit-grid wishlist-edit-layout wishlist-edit-layout-compact">
          <div class="form-group wishlist-form-preview-field wishlist-edit-preview-slot">
            <label class="form-label"><%= t('wishlist.photoPreview') %></label>
            <button
              class="wishlist-photo-preview wishlist-photo-preview-wide wishlist-edit-photo-button"
              id="wishlistEditImagePreview<%= item.id %>"
              type="button"
              data-current-src="<%= item.image_url || '' %>"
              data-empty-label="<%= t('wishlist.noImage') %>"
              data-existing-local="<%= isLocalWishlistImage(item.image_url) ? '1' : '0' %>"
              data-wishlist-upload-trigger="editLocalImage<%= item.id %>"
              aria-label="<%= t('wishlist.uploadLocalPhoto') %>"
            >
              <% if (item.image_url) { %>
                <img src="<%= item.image_url %>" alt="<%= item.title %> preview" />
              <% } else { %>
                <i class="bi bi-image"></i>
                <span><%= t('wishlist.noImage') %></span>
              <% } %>
            </button>
            <small class="wishlist-edit-preview-hint"><%= t('wishlist.clickToUploadLocalPhoto') %></small>
            <button
              class="btn btn-outline-secondary rounded-pill wishlist-edit-preview-reset"
              type="button"
              data-wishlist-reset-preview="wishlistEditImagePreview<%= item.id %>"
              data-wishlist-reset-file="editLocalImage<%= item.id %>"
              data-wishlist-reset-url="editImage<%= item.id %>"
              data-wishlist-reset-local="resetLocalImage<%= item.id %>"
            >
              <%= t('wishlist.resetPreview') %>
            </button>
            <input
              class="visually-hidden"
              id="editLocalImage<%= item.id %>"
              name="local_image"
              type="file"
              accept="image/*"
              data-wishlist-image-file-preview="wishlistEditImagePreview<%= item.id %>"
            />
          </div>

          <div class="wishlist-edit-fields-panel">
            <div class="wishlist-edit-main-row">
              <div class="form-group">
                <label class="form-label" for="editTitle<%= item.id %>"><%= t('wishlist.itemName') %></label>
                <input class="form-control" id="editTitle<%= item.id %>" name="title" value="<%= item.title %>" required />
              </div>

              <div class="form-group">
                <label class="form-label" for="editAmount<%= item.id %>"><%= t('wishlist.targetPrice') %></label>
                <div class="wishlist-price-field">
                  <span>€</span>
                  <input class="form-control" id="editAmount<%= item.id %>" name="amount" type="number" step="0.01" min="0.01" value="<%= Number(item.amount || 0).toFixed(2) %>" required />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="editFolder<%= item.id %>"><%= t('wishlist.folder') %></label>
                <select class="form-select" id="editFolder<%= item.id %>" name="folder">
                  <option value="" <%= !item.folder ? 'selected' : '' %>><%= t('wishlist.noFolder') %></option>
                  <% pageFolders.forEach((folder) => { %>
                    <option value="<%= folder %>" <%= item.folder === folder ? 'selected' : '' %>><%= folder %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="editDescription<%= item.id %>"><%= t('wishlist.description') %></label>
              <textarea class="form-control wishlist-edit-description" id="editDescription<%= item.id %>" name="description" rows="4"><%= item.description || '' %></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="editImage<%= item.id %>"><%= t('wishlist.imageLink') %></label>
              <input class="form-control" id="editImage<%= item.id %>" name="image_url" type="text" value="<%= editableImageLink %>" data-wishlist-image-url-preview="wishlistEditImagePreview<%= item.id %>" data-wishlist-reset-local="resetLocalImage<%= item.id %>" />
            </div>

            <div class="form-group">
              <label class="form-label" for="editProduct<%= item.id %>"><%= t('wishlist.productLink') %></label>
              <input class="form-control" id="editProduct<%= item.id %>" name="product_url" type="url" value="<%= item.product_url || '' %>" />
            </div>

          </div>


            <details class="wishlist-create-advanced wishlist-edit-advanced-details">
              <summary>
                <%= t('wishlist.additionalSettings') %>
                <i class="bi bi-chevron-down"></i>
              </summary>
              <div class="wishlist-create-advanced-grid">
                <div class="form-group">
                  <label class="form-label" for="editStatus<%= item.id %>"><%= t('wishlist.statusLabel') %></label>
                  <select class="form-select" id="editStatus<%= item.id %>" name="status">
                    <option value="planned" <%= item.status === 'planned' ? 'selected' : '' %>><%= t('wishlist.status.planned') %></option>
                    <option value="postponed" <%= item.status === 'postponed' ? 'selected' : '' %>><%= t('wishlist.status.postponed') %></option>
                    <option value="bought" <%= item.status === 'bought' ? 'selected' : '' %>><%= t('wishlist.status.bought') %></option>
                    <option value="cancelled" <%= item.status === 'cancelled' ? 'selected' : '' %>><%= t('wishlist.status.cancelled') %></option>
                  </select>
                </div>

                <div class="form-group">
                  <label class="form-label" for="editBuyer<%= item.id %>"><%= t('wishlist.whoWantsToBuyIt') %></label>
                  <select class="form-select" id="editBuyer<%= item.id %>" name="user_id">
                    <% if (pageFamilyMembers.length > 0) { %>
                      <% pageFamilyMembers.forEach((member) => { %>
                        <option value="<%= member.id %>" <%= Number(item.user_id) === Number(member.id) ? 'selected' : '' %>><%= member.name || member.email || t('wishlist.familyMember') %></option>
                      <% }) %>
                    <% } else { %>
                      <option value="<%= item.user_id %>" selected><%= item.buyer_name || t('wishlist.other') %></option>
                    <% } %>
                  </select>
                </div>

                <div class="form-group">
                  <label class="form-label" for="editDesiredDate<%= item.id %>"><%= t('wishlist.desiredBy') %></label>
                  <input class="form-control" id="editDesiredDate<%= item.id %>" name="desired_date" type="date" value="<%= item.desired_date ? String(item.desired_date).slice(0, 10) : '' %>" />
                </div>
              </div>
            </details>
        </div>

        <div class="wishlist-form-actions d-flex flex-wrap gap-2 justify-content-end mt-3">
          <button class="btn btn-outline-secondary rounded-pill px-4" type="button" data-wishlist-item-modal-close><%= t('wishlist.cancel') %></button>
          <button class="btn btn-primary rounded-pill px-4" type="submit"><%= t('wishlist.saveChanges') %></button>
        </div>
      </form>
    </div>

    <div class="wishlist-modal" id="wishlistItemDeleteModal" hidden>
      <div class="wishlist-modal-backdrop" data-wishlist-item-modal-close></div>
      <form class="wishlist-modal-card card border-0 rounded-4 wishlist-delete-item-modal" id="wishlistItemDeleteForm" action="/wishlist/<%= item.id %>/delete" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="wishlist-modal-header">
          <div>
            <p class="section-label"><%= t('wishlist.deleteItem') %></p>
            <h3 id="wishlistItemDeleteTitle"><%= t('wishlist.deleteItemQuestionWithName').replace('{name}', item.title) %></h3>
          </div>
          <button type="button" class="wishlist-modal-close" data-wishlist-item-modal-close aria-label="<%= t('wishlist.closeDeleteDialog') %>"><i class="bi bi-x-lg"></i></button>
        </div>
        <p class="wishlist-modal-text"><%= t('wishlist.actionCannotBeUndone') %></p>
        <div class="wishlist-modal-actions justify-content-end">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-wishlist-item-modal-close><%= t('wishlist.cancel') %></button>
          <button type="submit" class="btn btn-danger rounded-pill px-4"><%= t('wishlist.deleteItem') %></button>
        </div>
      </form>
    </div>
  <% } %>

  <% if (item.image_url) { %>
    <div class="wishlist-modal wishlist-image-modal" id="wishlistImageModal" hidden>
      <div class="wishlist-modal-backdrop" data-wishlist-image-close></div>
      <div class="wishlist-modal-card card border-0 rounded-4 wishlist-image-modal-card">
        <button type="button" class="wishlist-modal-close wishlist-image-modal-close" data-wishlist-image-close aria-label="<%= t('wishlist.closeImage') %>"><i class="bi bi-x-lg"></i></button>
        <img id="wishlistImageModalImg" src="" alt="<%= t('wishlist.wishlistItemImage') %>" />
        <div class="wishlist-image-modal-footer">
          <strong id="wishlistImageModalTitle"><%= t('wishlist.itemImage') %></strong>
          <% if (canEditBudget) { %>
            <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" id="wishlistImageModalEditButton"><%= t('wishlist.editItem') %></button>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>
</section>


<script>
  window.MyBudgetWishlistI18n = {
    addItem: <%- JSON.stringify(t('wishlist.addItem')) %>,
    hideForm: <%- JSON.stringify(t('wishlist.hideForm')) %>,
    showFolders: <%- JSON.stringify(t('wishlist.showFolders')) %>,
    hideFolders: <%- JSON.stringify(t('wishlist.hideFolders')) %>,
    preview: <%- JSON.stringify(t('wishlist.preview')) %>,
    noImage: <%- JSON.stringify(t('wishlist.noImage')) %>,
    photoPreview: <%- JSON.stringify(t('wishlist.photoPreview')) %>,
    deleteItemQuestion: <%- JSON.stringify(t('wishlist.deleteItemQuestionWithName')) %>,
    deleteFolderQuestion: <%- JSON.stringify(t('wishlist.deleteFolderQuestionWithName')) %>,
    item: <%- JSON.stringify(t('wishlist.item')) %>,
    itemSingular: <%- JSON.stringify(t('wishlist.itemSingular')) %>,
    itemPlural: <%- JSON.stringify(t('wishlist.itemPlural')) %>,
    folderContainsItems: <%- JSON.stringify(t('wishlist.folderContainsItems')) %>,
    chooseWhatToDoWithThem: <%- JSON.stringify(t('wishlist.chooseWhatToDoWithThem')) %>,
    folderEmptySafeDelete: <%- JSON.stringify(t('wishlist.folderEmptySafeDelete')) %>,
    wishlistItem: <%- JSON.stringify(t('wishlist.wishlistItem')) %>,
    image: <%- JSON.stringify(t('wishlist.image')) %>,
    itemImage: <%- JSON.stringify(t('wishlist.itemImage')) %>
  };
</script>

<script src="/js/wishlist.js"></script>

<%- include('../partials/footer') %>
